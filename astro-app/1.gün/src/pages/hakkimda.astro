---
import BaseLayout from '../layouts/BaseLayout.astro';

const beceriler = ['HTML', 'CSS', 'JavaScript', 'Astro'];
---

<BaseLayout title="Hakkımda | Portfolyo">
	<section class="about">
		<div class="avatar" aria-hidden="true">👨‍💻</div>
		<h1 class="page-title">Hakkımda</h1>
		<p class="bio">
			Merhaba! Bilgisayar mühendisliği okuyorum, boş zamanlarımda küçük web projeleri
			çıkarıyorum. HTML/CSS ile başladım, JavaScript'e geçtim; şimdi de Astro gibi
			framework'lerle statik siteleri daha hızlı kurmayı deniyorum. Yeni bir şey öğrenince
			hemen küçük bir demo yapma alışkanlığım var — bu site de tam öyle doğdu.
		</p>

		<h2 class="section-title">Beceriler</h2>
		<ul class="skills">
			{
				beceriler.map((beceri) => (
					<li class="skill-badge">{beceri}</li>
				))
			}
		</ul>

		<p class="contact">
			İletişim: <a href="mailto:emre@ornek.com">emre@ornek.com</a>
		</p>
	</section>
</BaseLayout>

<style>
	.about {
		max-width: 640px;
	}

	.avatar {
		width: 96px;
		height: 96px;
		background: rgba(56, 189, 248, 0.15);
		border: 2px solid rgba(56, 189, 248, 0.3);
		border-radius: 1rem;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 2.5rem;
		margin-bottom: 1.5rem;
	}

	.page-title {
		font-size: 2rem;
		color: #f8fafc;
		margin-bottom: 1rem;
	}

	.bio {
		color: #cbd5e1;
		line-height: 1.7;
		margin-bottom: 2rem;
	}

	.section-title {
		font-size: 1.125rem;
		color: #94a3b8;
		margin-bottom: 0.75rem;
		font-weight: 600;
	}

	.skills {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 2rem;
	}

	.skill-badge {
		background: rgba(99, 102, 241, 0.2);
		color: #a5b4fc;
		border: 1px solid rgba(99, 102, 241, 0.3);
		padding: 0.375rem 1rem;
		border-radius: 9999px;
		font-size: 0.875rem;
		font-weight: 500;
	}

	.contact {
		color: #94a3b8;
		font-size: 0.9375rem;
	}
</style>

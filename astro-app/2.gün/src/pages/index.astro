---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const sonYazilar = posts.slice(0, 3);
---

<BaseLayout title="Ana Sayfa | Portfolyo">
	<section class="hero">
		<p class="greeting">Merhaba, ben</p>
		<h1 class="name">Emre</h1>
		<p class="subtitle">Web geliştirici · Astro ile denemeler</p>
		<p class="intro">
			İnternette düzgün çalışan, sade siteler yapmayı seviyorum.
			Bu site Gün 1 portfolyosunun üzerine Gün 2 blog özellikleri eklenerek büyütüldü —
			content collections, dinamik route'lar ve Markdown/MDX entegrasyonu burada.
		</p>
		<div class="actions">
			<a href="/projeler" class="cta">Projelere göz at</a>
			<a href="/blog" class="cta secondary">Bloga git</a>
		</div>
	</section>

	{
		sonYazilar.length > 0 && (
			<section class="recent">
				<h2 class="section-title">Son yazılar</h2>
				<div class="grid">
					{sonYazilar.map((post) => (
						<PostCard post={post} />
					))}
				</div>
			</section>
		)
	}
</BaseLayout>

<style>
	.hero {
		text-align: center;
		padding: 4rem 1rem 2rem;
	}

	.greeting {
		color: #94a3b8;
		font-size: 1.125rem;
		margin-bottom: 0.5rem;
	}

	.name {
		font-size: clamp(2.5rem, 6vw, 3.5rem);
		font-weight: 800;
		background: linear-gradient(135deg, #38bdf8, #818cf8);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 0.75rem;
	}

	.subtitle {
		color: #64748b;
		font-size: 1.125rem;
		margin-bottom: 1.5rem;
	}

	.intro {
		max-width: 540px;
		margin: 0 auto 2rem;
		color: #cbd5e1;
		font-size: 1.0625rem;
		line-height: 1.7;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		justify-content: center;
	}

	.cta {
		display: inline-block;
		background: linear-gradient(135deg, #0ea5e9, #6366f1);
		color: #fff;
		font-weight: 600;
		padding: 0.875rem 2rem;
		border-radius: 0.75rem;
		text-decoration: none;
		transition: opacity 0.2s, transform 0.2s;
	}

	.cta.secondary {
		background: rgba(30, 41, 59, 0.8);
		border: 1px solid rgba(148, 163, 184, 0.3);
		color: #e2e8f0;
	}

	.cta:hover {
		opacity: 0.9;
		transform: translateY(-1px);
		text-decoration: none;
	}

	.recent {
		margin-top: 3rem;
	}

	.section-title {
		font-size: 1.5rem;
		color: #f8fafc;
		margin-bottom: 1.25rem;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 1.25rem;
	}
</style>

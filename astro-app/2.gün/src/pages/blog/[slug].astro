---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, category } = post.data;
const { Content } = await render(post);

const formattedDate = pubDate.toLocaleDateString('tr-TR', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<BaseLayout title={`${title} | Blog`}>
	<article class="post">
		<a href="/blog" class="back-link">← Blog'a dön</a>

		<header class="post-header">
			<span class="badge">{category}</span>
			<h1 class="post-title">{title}</h1>
			<p class="post-desc">{description}</p>
			<time class="post-date" datetime={pubDate.toISOString()}>{formattedDate}</time>
		</header>

		<div class="prose">
			<Content />
		</div>
	</article>
</BaseLayout>

<style>
	.back-link {
		display: inline-block;
		color: #94a3b8;
		font-size: 0.9375rem;
		margin-bottom: 1.5rem;
	}

	.back-link:hover {
		color: #38bdf8;
	}

	.post-header {
		margin-bottom: 2rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid rgba(148, 163, 184, 0.2);
	}

	.badge {
		display: inline-block;
		background: rgba(56, 189, 248, 0.15);
		color: #38bdf8;
		font-size: 0.75rem;
		font-weight: 600;
		padding: 0.25rem 0.75rem;
		border-radius: 9999px;
		margin-bottom: 0.75rem;
		text-transform: capitalize;
	}

	.post-title {
		font-size: clamp(1.75rem, 4vw, 2.25rem);
		color: #f8fafc;
		margin-bottom: 0.75rem;
		line-height: 1.3;
	}

	.post-desc {
		color: #94a3b8;
		font-size: 1.0625rem;
		margin-bottom: 0.75rem;
	}

	.post-date {
		color: #64748b;
		font-size: 0.875rem;
	}

	.prose :global(h2) {
		font-size: 1.375rem;
		color: #f8fafc;
		margin: 2rem 0 0.75rem;
	}

	.prose :global(h3) {
		font-size: 1.125rem;
		color: #e2e8f0;
		margin: 1.5rem 0 0.5rem;
	}

	.prose :global(p) {
		color: #cbd5e1;
		line-height: 1.7;
		margin-bottom: 1rem;
	}

	.prose :global(ul),
	.prose :global(ol) {
		color: #cbd5e1;
		margin: 0 0 1rem 1.25rem;
		line-height: 1.7;
	}

	.prose :global(li) {
		margin-bottom: 0.375rem;
	}

	.prose :global(code) {
		background: rgba(15, 23, 42, 0.8);
		color: #38bdf8;
		padding: 0.125rem 0.375rem;
		border-radius: 0.25rem;
		font-size: 0.875em;
	}

	.prose :global(pre) {
		background: rgba(15, 23, 42, 0.9);
		border: 1px solid rgba(148, 163, 184, 0.15);
		border-radius: 0.75rem;
		padding: 1rem 1.25rem;
		overflow-x: auto;
		margin: 1rem 0 1.5rem;
	}

	.prose :global(pre code) {
		background: none;
		padding: 0;
		color: #e2e8f0;
	}

	.prose :global(a) {
		color: #38bdf8;
	}
</style>

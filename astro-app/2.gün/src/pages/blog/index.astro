---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import CategoryFilter from '../../components/CategoryFilter.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = [...new Set(posts.map((post) => post.data.category))];

const response = await fetch('https://jsonplaceholder.typicode.com/users/1');
const yazar = await response.json();
---

<BaseLayout title="Blog | Portfolyo">
	<section class="blog">
		<h1 class="page-title">Blog</h1>
		<p class="page-desc">
			Markdown ve MDX ile yazılmış notlar. Content collections ve dinamik route'larla üretiliyor.
		</p>

		<aside class="fetch-demo">
			<p class="fetch-label">Build-time fetch örneği</p>
			<p class="fetch-text">
				Yazar: <strong>{yazar.name}</strong> · {yazar.email}
			</p>
		</aside>

		<CategoryFilter categories={categories} />

		<div class="grid">
			{posts.map((post) => <PostCard post={post} />)}
		</div>
	</section>
</BaseLayout>

<style>
	.page-title {
		font-size: 2rem;
		color: #f8fafc;
		margin-bottom: 0.5rem;
	}

	.page-desc {
		color: #94a3b8;
		margin-bottom: 1.5rem;
	}

	.fetch-demo {
		background: rgba(30, 41, 59, 0.6);
		border: 1px solid rgba(148, 163, 184, 0.15);
		border-radius: 0.75rem;
		padding: 1rem 1.25rem;
		margin-bottom: 1.5rem;
	}

	.fetch-label {
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: #64748b;
		margin-bottom: 0.25rem;
	}

	.fetch-text {
		color: #cbd5e1;
		font-size: 0.9375rem;
	}

	.fetch-text strong {
		color: #38bdf8;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 1.25rem;
	}
</style>

---
import AppLayout from '../layouts/AppLayout.astro';
import { getDemoCredentials, readSessionUser, SESSION_COOKIE } from '../lib/auth';

const user = await readSessionUser(Astro.cookies.get(SESSION_COOKIE)?.value);

if (user) {
  return Astro.redirect('/dashboard');
}

const error = Astro.url.searchParams.get('error');
const credentials = getDemoCredentials();
---

<AppLayout title="Giris - CV Lens Hazirlik">
  <section class="login-layout">
    <form class="login-box" action="/api/login" method="post">
      <p class="eyebrow">Form handling + API endpoint</p>
      <h1>Giris</h1>
      <p class="muted">
        Demo hesap: <strong>{credentials.email}</strong> / <strong>{credentials.password}</strong>
      </p>

      {error && <div class="alert">Email veya sifre hatali.</div>}

      <div class="field">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" autocomplete="email" required value={credentials.email} />
      </div>

      <div class="field">
        <label for="password">Sifre</label>
        <input
          id="password"
          name="password"
          type="password"
          autocomplete="current-password"
          required
          value={credentials.password}
        />
      </div>

      <button class="button primary" type="submit">Giris yap</button>
    </form>
  </section>
</AppLayout>

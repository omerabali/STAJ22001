{
  "name": "astro-project",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --background",
    "dev:server": "npm run dev --prefix server",
    "dev:astro": "astro dev --background && astro dev logs --follow",
    "dev:all": "concurrently --kill-others-on-fail --names \"ASTRO,SERVER\" --prefix-colors \"cyan,yellow\" \"npm run dev:astro\" \"npm run dev:server\"",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.2",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}

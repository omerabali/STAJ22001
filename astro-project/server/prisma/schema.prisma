datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  CANDIDATE
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  phone        String   @unique
  passwordHash String
  role         Role     @default(CANDIDATE)
  name         String?
  avatarUrl    String?
  resetCode    String?
  resetCodeExpires DateTime?
  createdAt    DateTime @default(now())

  @@map("users")
}
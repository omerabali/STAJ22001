datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  CANDIDATE
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  phone        String   @unique
  passwordHash String
  role         Role     @default(CANDIDATE)
  name         String?
  avatarUrl    String?
  resetCode    String?
  resetCodeExpires DateTime?
  createdAt    DateTime @default(now())
  analyses     Analysis[]

  @@map("users")
}

model Analysis {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName      String
  fileUrl       String
  extractedText String?
  status        String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  atsScore      Int?
  skills        Json?
  strengths     Json?
  weaknesses    Json?
  suggestions   Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("analyses")
}
---
interface Props {
  variant?: "primary" | "secondary" | "success" | "warning" | "error" | "default";
  class?: string;
}

const { variant = "default", class: className = "" } = Astro.props;

const variantStyles = {
  primary: "bg-primary/10 text-primary border-primary/20",
  secondary: "bg-secondary-container text-on-secondary-container border-secondary-container/50",
  success: "bg-emerald-500/10 text-emerald-400 border-emerald-500/20",
  warning: "bg-amber-500/10 text-amber-400 border-amber-500/20",
  error: "bg-error/10 text-error border-error/20",
  default: "bg-surface-variant/50 text-on-surface-variant border-surface-variant"
};
---

<span class:list={[
  "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border",
  variantStyles[variant],
  className
]}>
  <slot />
</span>

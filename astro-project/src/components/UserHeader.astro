---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<header class="fixed top-0 right-0 w-full md:w-[calc(100%-260px)] h-24 bg-brand-bg border-b border-brand-border flex justify-between items-center px-4 md:px-10 z-40 transition-all duration-300">
  <div class="flex items-center gap-2">
    <button id="mobile-menu-btn" class="md:hidden w-10 h-10 rounded-full hover:bg-white/5 flex items-center justify-center text-brand-muted">
      <span class="material-symbols-outlined">menu</span>
    </button>
    <div class="flex items-baseline gap-4">
      <h2 class="text-2xl font-bold text-brand-text truncate max-w-[150px] sm:max-w-xs">{title}</h2>
    </div>
  </div>
  <div class="flex items-center gap-8">
    <div class="text-sm text-brand-muted font-medium hidden lg:block" id="header-date">
      <!-- Will be updated dynamically -->
    </div>
    
    <!-- User Profile Badge -->
    <button class="flex items-center gap-3 bg-brand-card hover:bg-brand-border/50 border border-brand-border rounded-full py-1.5 pr-2 pl-5 transition-all focus:outline-none focus:ring-2 focus:ring-brand-accent" onclick="window.location.href='/settings'">
      <div class="text-right">
        <div class="text-sm font-bold text-brand-text leading-none" id="header-user-name">Yükleniyor...</div>
        <div class="text-[10px] text-brand-muted uppercase tracking-wider mt-1.5 font-bold">Kullanıcı</div>
      </div>
      <div id="header-user-avatar" class="w-10 h-10 rounded-full overflow-hidden border-2 border-brand-bg bg-cover bg-center shrink-0 flex items-center justify-center bg-brand-accent/10 border-brand-border hover:ring-2 hover:ring-brand-accent transition-all duration-300">
        <span id="user-avatar-initial" class="font-bold text-brand-accent">U</span>
      </div>
    </button>
  </div>
</header>

<script is:inline>
  const initUserHeader = async () => {
    try {
      const dateEl = document.getElementById('header-date');
      if (dateEl) {
        dateEl.textContent = new Date().toLocaleDateString('tr-TR', { 
          weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' 
        });
      }

      const res = await fetch('/api/auth/me');
      if (res.ok) {
        const data = await res.json();
        if (data.user) {
          let displayLabel = data.user.name || data.user.email;
          if (!data.user.name && data.user.email) {
            displayLabel = data.user.email.split('@')[0];
          }
          const headerNameEl = document.getElementById('header-user-name');
          if (headerNameEl) headerNameEl.textContent = displayLabel;
          
          const avatarContainer = document.getElementById('header-user-avatar');
          if (avatarContainer) {
            if (data.user.avatarUrl) {
              avatarContainer.style.backgroundImage = `url(${data.user.avatarUrl})`;
              avatarContainer.innerHTML = '';
            } else {
              avatarContainer.innerHTML = `<span id="user-avatar-initial" class="font-bold text-brand-accent">${displayLabel.charAt(0).toUpperCase()}</span>`;
            }
          }
        }
      }
    } catch (err) {
      console.error(err);
    }
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initUserHeader);
  } else {
    initUserHeader();
  }
</script>

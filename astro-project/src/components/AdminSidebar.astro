---
const currentPath = Astro.url.pathname;

const menuItems = [
    { name: 'Dashboard', path: '/admin/dashboard', icon: 'dashboard' },
    { name: 'Aday Ara', path: '/admin/search', icon: 'search' },
    { name: 'CV Yükle', path: '/admin/upload', icon: 'upload_file' },
    { name: 'Kullanıcı Yönetimi', path: '/admin/users', icon: 'group' },
    { name: 'Sistem Ayarları', path: '/admin/settings', icon: 'settings' },
    { name: 'Raporlar', path: '/admin/reports', icon: 'analytics' }
];

const bottomItems = [
    { name: 'Çıkış', path: '#', icon: 'logout', isLogout: true }
];
---

<nav id="admin-sidebar" class="w-[280px] h-screen fixed left-0 top-0 bg-[#f5f4f0] border-r border-[#ddd9d3] flex flex-col z-50 transform -translate-x-full md:translate-x-0 transition-transform duration-300 ease-in-out">
    <!-- Brand / Logo Area -->
    <div class="p-6 border-b border-[#ddd9d3] relative overflow-hidden">
        <div class="flex items-center gap-3 mb-1.5 relative z-10">
            <img src="/mixboard-image.png" alt="Beacon Logo" class="h-9 w-auto object-contain" />
            <h1 class="font-headline-md text-headline-md font-bold text-[#1b1c1a] tracking-tight">Beacon</h1>
        </div>
        <p class="font-label-xs text-label-xs text-[#14422f] uppercase tracking-widest font-mono relative z-10 font-bold">SYSTEM CONTROL</p>
    </div>
    
    <!-- Menu items -->
    <div class="flex-1 flex flex-col gap-1 mt-6 px-3">
        {menuItems.map((item) => {
            const isActive = currentPath === item.path || (currentPath.startsWith(item.path) && item.path !== '/admin/dashboard');
            return (
                <a 
                    href={item.path}
                    class:list={[
                        "group flex items-center gap-4 px-4 py-3 font-body-md text-body-md rounded-lg transition-all duration-200 relative overflow-hidden",
                        isActive 
                            ? "bg-white text-[#14422f] border-l-3 border-[#14422f] shadow-sm font-semibold"
                            : "text-[#8a8580] hover:bg-white/40 hover:text-[#1b1c1a]"
                    ]}
                >
                    <span class:list={[
                        "material-symbols-outlined transition-transform duration-200",
                        isActive ? "scale-105 text-[#14422f]" : "group-hover:scale-105 group-hover:text-[#14422f]"
                    ]}>{item.icon}</span>
                    <span class="relative z-10 transition-colors duration-200 text-sm tracking-wide font-medium font-sans">{item.name}</span>
                </a>
            );
        })}
    </div>

    <!-- Sidebar Bottom / Logout -->
    <div class="p-4 mt-auto border-t border-[#ddd9d3]">
        <div class="flex flex-col gap-1">
            {bottomItems.map((item) => (
                <a 
                    href={item.path}
                    onclick={item.isLogout ? "event.preventDefault(); handleLogout();" : ""}
                    class="group flex items-center gap-4 px-4 py-3 text-[#8a8580] hover:bg-red-50 hover:text-[#ef4444] rounded-lg transition-all duration-200 font-body-md text-body-md"
                >
                    <span class="material-symbols-outlined transition-transform duration-200 group-hover:scale-105 group-hover:text-[#ef4444]">{item.icon}</span>
                    <span class="transition-colors duration-200 text-sm font-medium font-sans">{item.name}</span>
                </a>
            ))}
        </div>
    </div>
</nav>

<script is:inline>
    async function handleLogout() {
        try {
            await fetch('/api/auth/logout', { method: 'POST' });
            window.location.href = '/';
        } catch (err) {
            console.error("Çıkış yapılırken hata oluştu:", err);
            window.location.href = '/';
        }
    }
</script>

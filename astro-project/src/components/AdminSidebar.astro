---
const currentPath = Astro.url.pathname;

const menuItems = [
    { name: 'Dashboard', path: '/admin/dashboard', icon: 'dashboard' },
    { name: 'Aday Ara', path: '/admin/search', icon: 'search' },
    { name: 'Kullanıcı Yönetimi', path: '/admin/users', icon: 'group' },
    { name: 'Sistem Ayarları', path: '/admin/settings', icon: 'settings' },
    { name: 'Raporlar', path: '/admin/reports', icon: 'analytics' }
];

const bottomItems = [
    { name: 'Çıkış', path: '#', icon: 'logout', isLogout: true }
];
---

<nav id="admin-sidebar" class="w-[280px] h-screen fixed left-0 top-0 bg-surface-container-lowest border-r border-outline-variant flex flex-col z-50 transform -translate-x-full md:translate-x-0 transition-transform duration-300 ease-in-out">
    <div class="p-6">
        <div class="flex items-center gap-2 mb-1">
            <img src="/mixboard.png" alt="Beacon Logo" class="h-6 w-auto object-contain" />
            <h1 class="font-headline-md text-headline-md font-bold text-primary">Beacon</h1>
        </div>
        <p class="font-label-md text-label-md text-on-surface-variant">Admin Control</p>
    </div>
    
    <div class="flex-1 flex flex-col gap-2 mt-4">
        {menuItems.map((item) => {
            const isActive = currentPath === item.path || (currentPath.startsWith(item.path) && item.path !== '/admin/dashboard');
            return (
                <a 
                    href={item.path}
                    class:list={[
                        "group flex items-center gap-4 px-4 py-3 font-body-md text-body-md transition-all duration-300 relative overflow-hidden",
                        isActive 
                            ? "bg-secondary-container text-on-secondary-container border-l-4 border-primary shadow-[inset_4px_0_0_0_rgba(124,58,237,1)]"
                            : "text-on-surface-variant hover:bg-surface-container-high hover:text-on-surface border-l-4 border-transparent hover:border-outline-variant hover:translate-x-1"
                    ]}
                >
                    <span class:list={[
                        "material-symbols-outlined transition-transform duration-300",
                        isActive ? "scale-110" : "group-hover:scale-110 group-hover:text-primary"
                    ]}>{item.icon}</span>
                    <span class="relative z-10 transition-colors duration-300">{item.name}</span>
                </a>
            );
        })}
    </div>

    <div class="p-4 mt-auto">
        <div class="flex flex-col gap-2 border-t border-outline-variant pt-4">
            {bottomItems.map((item) => (
                <a 
                    href={item.path}
                    onclick={item.isLogout ? "event.preventDefault(); handleLogout();" : ""}
                    class="group flex items-center gap-4 px-4 py-2 text-on-surface-variant hover:bg-surface-container-high hover:text-on-surface transition-all duration-300 font-body-md text-body-md rounded-lg hover:translate-x-1"
                >
                    <span class="material-symbols-outlined transition-transform duration-300 group-hover:scale-110 group-hover:text-primary">{item.icon}</span>
                    <span class="transition-colors duration-300">{item.name}</span>
                </a>
            ))}
        </div>
    </div>
</nav>

<script is:inline>
    async function handleLogout() {
        try {
            await fetch('/api/auth/logout', { method: 'POST' });
            window.location.href = '/';
        } catch (err) {
            console.error("Çıkış yapılırken hata oluştu:", err);
            window.location.href = '/';
        }
    }
</script>

---
const currentPath = Astro.url.pathname;
---
<nav id="user-sidebar" class="fixed left-0 top-0 h-full w-[260px] bg-surface-container border-r border-outline-variant flex flex-col z-50 transform -translate-x-full md:translate-x-0 transition-transform duration-300">
  <div class="p-6 border-b border-outline-variant/30 bg-surface-container-low/30 backdrop-blur-sm relative overflow-hidden">
    <!-- Subtle glow behind the logo -->
    <div class="absolute -top-10 -left-10 w-32 h-32 bg-primary/10 rounded-full blur-2xl pointer-events-none"></div>
    
    <div class="flex items-center gap-3 relative z-10">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-primary to-primary-container flex items-center justify-center shadow-lg shadow-primary/20 shrink-0">
        <img src="/mixboard.png" alt="Beacon" class="h-6 w-auto object-contain" />
      </div>
      <div class="flex flex-col">
        <h1 class="text-[20px] font-bold text-on-surface leading-tight tracking-tight">Beacon AI</h1>
        <div class="flex items-center gap-1.5 mt-0.5">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
          <span class="text-[11px] font-bold tracking-widest text-primary uppercase" id="portal-subtitle">Aday Portalı</span>
        </div>
      </div>
    </div>
  </div>
  
  <div class="flex-1 overflow-y-auto mt-md flex flex-col gap-xs py-sm">
    <a class={`px-lg py-md transition-colors flex items-center gap-md ml-1 ${currentPath === '/dashboard' ? 'text-primary font-bold border-l-4 border-primary bg-secondary-container/10 opacity-90' : 'text-on-surface-variant hover:bg-surface-variant/50'}`} href="/dashboard">
      <span class="material-symbols-outlined" style="font-size:20px">cloud_upload</span>
      CV Yükle & Analiz
    </a>
    <a class={`px-lg py-md transition-colors flex items-center gap-md ml-1 ${currentPath === '/analyses' ? 'text-primary font-bold border-l-4 border-primary bg-secondary-container/10 opacity-90' : 'text-on-surface-variant hover:bg-surface-variant/50'}`} href="/analyses">
      <span class="material-symbols-outlined" style="font-size:20px">analytics</span>
      Analiz Sonuçlarım
    </a>
  </div>

  <div class="flex-col flex gap-xs py-sm border-t border-outline-variant/30 mt-auto">
    <div class="flex-1"></div>
    <a class={`px-lg py-md transition-colors flex items-center gap-md ml-1 border-t border-outline-variant/30 pt-md ${currentPath === '/settings' ? 'text-primary font-bold border-l-4 border-primary bg-secondary-container/10' : 'text-on-surface-variant hover:bg-surface-variant/50'}`} href="/settings">
      <span class="material-symbols-outlined" style="font-size:20px">settings</span>
      Ayarlar
    </a>
    <button onclick="handleUserLogout()" class="text-on-surface-variant px-lg py-md hover:bg-error/10 hover:text-error transition-colors flex items-center gap-md ml-1 w-full text-left">
      <span class="material-symbols-outlined" style="font-size:20px">logout</span>
      Çıkış Yap
    </button>
  </div>
</nav>

<script is:inline>
  async function handleUserLogout() {
    try {
      await fetch('/api/auth/logout', { method: 'POST', credentials: 'include' });
    } catch (e) {
      console.error(e);
    }
    window.location.href = '/';
  }
</script>

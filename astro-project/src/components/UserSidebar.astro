---
const currentPath = Astro.url.pathname;
---
<nav id="user-sidebar" class="fixed left-0 top-0 h-full w-[260px] bg-brand-bg border-r border-brand-border flex flex-col z-50 transform -translate-x-full md:translate-x-0 transition-transform duration-300">
  <!-- Logo Area -->
  <div class="h-24 flex items-center px-8 border-b border-brand-border shrink-0">
    <div class="w-10 h-10 rounded-xl bg-brand-card flex items-center justify-center border border-brand-border shadow-sm mr-3">
      <i class="fa-solid fa-cube text-brand-accent text-xl"></i>
    </div>
    <div>
      <h1 class="font-bold text-lg leading-tight tracking-wide text-brand-text">Beacon AI</h1>
      <span class="text-[10px] uppercase tracking-widest text-brand-success font-semibold flex items-center gap-1">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-success animate-pulse"></span>
        Aday Portalı
      </span>
    </div>
  </div>
  
  <!-- Navigation -->
  <div class="flex-1 overflow-y-auto mt-8 px-4 space-y-2">
    <a class={`flex items-center px-4 py-3.5 rounded-r-2xl transition-all group relative overflow-hidden ${currentPath === '/profile' ? 'text-brand-text glass-active' : 'text-brand-muted hover:text-brand-text hover:bg-white/5'}`} href="/profile">
      <i class="fa-solid fa-cloud-arrow-up text-brand-accent w-6 text-center relative z-10"></i>
      <span class="ml-3 font-semibold relative z-10">CV Yükle & Analiz</span>
    </a>
    <a class={`flex items-center px-4 py-3.5 rounded-r-2xl transition-all group relative overflow-hidden ${currentPath === '/analyses' ? 'text-brand-text glass-active' : 'text-brand-muted hover:text-brand-text hover:bg-white/5'}`} href="/analyses">
      <i class="fa-solid fa-chart-pie w-6 text-center group-hover:text-brand-accent transition-colors relative z-10"></i>
      <span class="ml-3 font-semibold relative z-10">Analiz Sonuçlarım</span>
    </a>
  </div>

  <!-- Bottom Actions -->
  <div class="px-4 pb-8 space-y-2 mt-auto">
    <a class={`flex items-center px-4 py-3 rounded-xl transition-all group ${currentPath === '/settings' ? 'text-brand-text glass-active' : 'text-brand-muted hover:text-brand-text hover:bg-white/5'}`} href="/settings">
      <i class="fa-solid fa-gear w-6 text-center group-hover:text-brand-accent transition-colors"></i>
      <span class="ml-3 text-sm font-medium">Ayarlar</span>
    </a>
    <button onclick="handleUserLogout()" class="flex items-center px-4 py-3 text-brand-muted hover:text-brand-danger hover:bg-red-500/10 rounded-xl transition-all group w-full text-left">
      <i class="fa-solid fa-arrow-right-from-bracket w-6 text-center"></i>
      <span class="ml-3 text-sm font-medium">Çıkış Yap</span>
    </button>
  </div>
</nav>

<script is:inline>
  async function handleUserLogout() {
    try {
      await fetch('/api/auth/logout', { method: 'POST', credentials: 'include' });
    } catch (e) {
      console.error(e);
    }
    window.location.href = '/';
  }
</script>

---
---

<header class="flex justify-between items-center mb-8 pb-4 border-b border-outline-variant">
  <div class="flex items-center gap-4">
    <button id="admin-mobile-menu-btn" class="md:hidden w-10 h-10 rounded-full bg-surface-container-high flex items-center justify-center text-on-surface hover:bg-primary hover:text-white transition-all shadow-sm">
      <span class="material-symbols-outlined">menu</span>
    </button>
  </div>
  
  <div class="flex items-center gap-4 bg-surface-container-highest px-4 py-2 rounded-xl border border-outline-variant shadow-sm transition-all duration-300 hover:shadow-[0_4px_15px_rgba(124,58,237,0.1)] hover:border-primary/30">
    <div class="text-right hidden sm:block">
      <p class="font-label-md text-label-md text-on-surface font-bold" id="header-user-name">Yükleniyor...</p>
      <p class="font-label-sm text-label-sm text-primary uppercase tracking-wider font-bold" id="header-user-role">ADMIN</p>
    </div>
    
    <div id="header-user-avatar" class="w-10 h-10 rounded-full bg-primary-container text-on-primary-container flex items-center justify-center font-bold shadow-[0_0_10px_rgba(124,58,237,0.2)] bg-cover bg-center cursor-pointer hover:ring-2 hover:ring-primary hover:scale-105 transition-all duration-300 overflow-hidden">
      <span class="material-symbols-outlined text-[20px]">person</span>
    </div>
  </div>
</header>

<script is:inline>
  document.addEventListener("DOMContentLoaded", async () => {
    try {
      const res = await fetch('/api/auth/me');
      if (res.ok) {
        const data = await res.json();
        if (data.user) {
          const nameEl = document.getElementById('header-user-name');
          const roleEl = document.getElementById('header-user-role');
          const avatarEl = document.getElementById('header-user-avatar');
          
          if (nameEl) nameEl.textContent = data.user.name || data.user.email;
          if (roleEl) roleEl.textContent = data.user.role === 'ADMIN' ? 'YÖNETİCİ' : 'KULLANICI';
          
          if (avatarEl) {
            if (data.user.avatarUrl) {
              avatarEl.style.backgroundImage = `url(${data.user.avatarUrl})`;
              avatarEl.innerHTML = '';
            } else if (data.user.email) {
              avatarEl.textContent = (data.user.name || data.user.email).charAt(0).toUpperCase();
              avatarEl.style.backgroundImage = 'none';
            }
          }
        }
      }
    } catch (err) {
      console.error("Header kullanıcı bilgisi alınamadı", err);
    }
  });
</script>

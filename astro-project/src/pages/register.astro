---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Beacon - Register">
	<div class="theme-register bg-[#0b0b18] text-on-surface font-body-md antialiased min-h-screen flex selection:bg-primary selection:text-on-primary">
		<div class="flex flex-col md:flex-row w-full min-h-screen">
			<!-- LEFT SIDE (Atmosphere) -->
			<div class="relative hidden md:flex flex-col justify-between w-1/2 p-16 bg-[#0d0d1a] overflow-hidden border-r border-surface-variant/30">
				<!-- Particle Animation Canvas -->
				<canvas id="particle-canvas" style="opacity: 0.18;"></canvas>
				<!-- Ambient Glow -->
				<div class="absolute bottom-0 left-0 w-3/4 h-3/4 bg-[#7c5cfc]/10 rounded-full blur-[120px] pointer-events-none transform -translate-x-1/3 translate-y-1/3"></div>
				<!-- Header / Logo -->
				<div class="relative z-10">
					<a class="font-display text-2xl font-bold text-on-surface flex items-center gap-2 cursor-pointer hover:opacity-90" href="/">
						<img src="/beacon.png" alt="Beacon Logo" class="h-6 w-auto object-contain" />
						Beacon <span class="text-[#7c5cfc]">•</span>
					</a>
				</div>
				<!-- Center Content -->
				<div class="relative z-10 flex flex-col gap-6 max-w-[500px] mt-[-10vh]">
					<h1 class="font-display text-3xl lg:text-4xl text-white font-bold leading-tight">
						Profesyonel profilini oluştur.
					</h1>
					<p class="font-body-md text-[#a3a3c2] text-lg mt-4">
						CV'ni yükle ve anlamlı analizler al.
					</p>
					<!-- Animated CV Flow Steps -->
					<div class="flex items-center gap-4 mt-8 animate-flow text-white">
						<div class="flex flex-col items-center gap-2">
							<span class="text-3xl">📄</span>
							<span class="font-label-sm tracking-wider uppercase whitespace-nowrap">CV Yükle</span>
						</div>
						<div class="flex-1 h-px border-t border-dashed border-white/40"></div>
						<div class="flex flex-col items-center gap-2">
							<span class="text-3xl">🔍</span>
							<span class="font-label-sm tracking-wider uppercase whitespace-nowrap">YZ Analizi</span>
						</div>
						<div class="flex-1 h-px border-t border-dashed border-white/40"></div>
						<div class="flex flex-col items-center gap-2">
							<span class="text-3xl">✓</span>
							<span class="font-label-sm tracking-wider uppercase whitespace-nowrap">Profil Hazır</span>
						</div>
					</div>
				</div>
				<!-- Spacer to push content center -->
				<div class="relative z-10 opacity-0">Bottom Spacer</div>
			</div>
			<!-- RIGHT SIDE (Form) -->
			<div class="flex-1 flex flex-col justify-center items-center p-6 md:p-16 bg-[#0b0b18] relative">
				<!-- Form Container -->
				<div class="w-full max-w-[420px] flex flex-col gap-8 z-10 relative border border-[rgba(255,255,255,0.05)] rounded-2xl p-8 bg-[#0b0b18]">
					<!-- Heading Area -->
					<div class="flex flex-col gap-2">
						<span class="font-label-sm text-[#6b6b9a] uppercase tracking-wider">BEACON</span>
						<h2 class="font-display text-headline-lg-mobile md:text-headline-lg text-white font-bold">
							Hesap oluştur
						</h2>
						<p class="font-body-md text-[#6b6b9a]">
							Hesabınızı oluşturup CV analizine başlayın.
						</p>
					</div>

					<div id="error-feedback" class="hidden w-full bg-red-950/40 border border-red-500/30 text-red-200 text-xs font-mono p-3 rounded-lg"></div>

					<!-- Form -->
					<form id="register-form" class="flex flex-col gap-6">
						<!-- Full Name -->
						<div class="flex flex-col gap-2">
							<label class="font-label-md text-on-surface-variant text-sm font-medium" for="fullname">Ad Soyad</label>
							<div class="relative group">
								<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[#6b6b9a]">person</span>
								<input class="w-full bg-[#13132b] border border-[#2a2a4a] text-white placeholder-[#a3a3c2] pl-11 pr-4 h-[48px] focus:outline-none focus:border-[#7c5cfc] focus:ring-1 focus:ring-[#7c5cfc] focus:shadow-[0_0_15px_rgba(124,92,252,0.15)] transition-all duration-300" id="fullname" placeholder="Adın Soyadın" type="text" required/>
							</div>
						</div>
						<!-- Email -->
						<div class="flex flex-col gap-2">
							<label class="font-label-md text-on-surface-variant text-sm font-medium" for="email">E-posta</label>
							<div class="relative group">
								<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[#6b6b9a]">mail</span>
								<input class="w-full bg-[#13132b] border border-[#2a2a4a] text-white placeholder-[#a3a3c2] pl-11 pr-4 h-[48px] focus:outline-none focus:border-[#7c5cfc] focus:ring-1 focus:ring-[#7c5cfc] focus:shadow-[0_0_15px_rgba(124,92,252,0.15)] transition-all duration-300" id="email" placeholder="ornek@email.com" type="email" required/>
							</div>
						</div>
						<!-- Password -->
						<div class="flex flex-col gap-2">
							<label class="font-label-md text-on-surface-variant text-sm font-medium" for="password">Şifre</label>
							<div class="relative group">
								<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[#6b6b9a]">lock</span>
								<input class="w-full bg-[#13132b] border border-[#2a2a4a] text-white placeholder-[#a3a3c2] pl-11 pr-12 h-[48px] focus:outline-none focus:border-[#7c5cfc] focus:ring-1 focus:ring-[#7c5cfc] focus:shadow-[0_0_15px_rgba(124,92,252,0.15)] transition-all duration-300" id="password" placeholder="••••••••" type="password" required autocomplete="new-password" value=""/>
								<button class="absolute right-3 top-1/2 -translate-y-1/2 text-[#6b6b9a] hover:text-white transition-colors" type="button" id="toggle-password">
									<span class="material-symbols-outlined text-xl select-none">visibility</span>
								</button>
							</div>
							<!-- Password Strength -->
							<div class="flex gap-1 mt-1 h-1.5 w-full" id="password-strength">
								<div class="flex-1 rounded-full bg-[#2a2a4a] transition-colors duration-300" id="strength-1"></div>
								<div class="flex-1 rounded-full bg-[#2a2a4a] transition-colors duration-300" id="strength-2"></div>
								<div class="flex-1 rounded-full bg-[#2a2a4a] transition-colors duration-300" id="strength-3"></div>
							</div>
							<span class="text-xs text-[#6b6b9a] mt-1 font-mono" id="strength-text">Şifre gücü</span>
						</div>
						<!-- Confirm Password -->
						<div class="flex flex-col gap-2">
							<label class="font-label-md text-on-surface-variant text-sm font-medium" for="confirm_password">Şifre Tekrar</label>
							<div class="relative group">
								<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[#6b6b9a]">lock</span>
								<input class="w-full bg-[#13132b] border border-[#2a2a4a] text-white placeholder-[#a3a3c2] pl-11 pr-12 h-[48px] focus:outline-none focus:border-[#7c5cfc] focus:ring-1 focus:ring-[#7c5cfc] focus:shadow-[0_0_15px_rgba(124,92,252,0.15)] transition-all duration-300" id="confirm_password" placeholder="••••••••" type="password" required autocomplete="new-password" value=""/>
								<button class="absolute right-3 top-1/2 -translate-y-1/2 text-[#6b6b9a] hover:text-white transition-colors" type="button" id="toggle-confirm-password">
									<span class="material-symbols-outlined text-xl select-none">visibility</span>
								</button>
							</div>
						</div>
						<!-- Remember Me Checkbox -->
						<div class="flex items-start gap-3 mt-1">
							<div class="relative flex items-center pt-0.5">
								<input class="appearance-none custom-checkbox h-[20px] w-[20px] shrink-0 rounded border border-slate-600 bg-[#13132b] focus:outline-none focus:border-[#7c5cfc] focus:ring-1 focus:ring-[#7c5cfc] hover:border-[#7c5cfc] cursor-pointer transition-colors relative" id="remember_me" type="checkbox"/>
							</div>
							<label class="font-body-md text-xs text-slate-400 leading-tight cursor-pointer" for="remember_me">
								Beni Hatırla
							</label>
						</div>
						<!-- Terms Checkbox -->
						<div class="flex items-start gap-3 mt-1">
							<div class="relative flex items-center pt-1">
								<input class="appearance-none custom-checkbox h-[20px] w-[20px] shrink-0 rounded border border-slate-600 bg-[#13132b] focus:outline-none focus:border-[#7c5cfc] focus:ring-1 focus:ring-[#7c5cfc] hover:border-[#7c5cfc] cursor-pointer transition-colors relative" id="terms" type="checkbox"/>
							</div>
							<label class="font-body-md text-xs text-slate-400 leading-tight cursor-pointer" for="terms">
								Hesap oluşturarak, <span class="text-[#a78bfa] underline hover:text-white transition-colors">Kullanım Şartları</span> ve <span class="text-[#a78bfa] underline hover:text-white transition-colors">Gizlilik Politikası</span>'nı kabul etmiş olursunuz.
							</label>
						</div>
						<!-- Submit Button -->
						<button class="w-full bg-[#7c5cfc] text-white font-label-md py-3 rounded mt-2 hover:bg-[#8b6fff] hover:-translate-y-[2px] transition-all duration-300 shadow-[0_0_20px_rgba(124,92,252,0.2)] hover:shadow-[0_0_30px_rgba(124,92,252,0.5)] flex justify-center items-center gap-2 group cursor-pointer" type="submit">
							Hesap Oluştur <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
						</button>
					</form>
					<!-- Footer Link -->
					<div class="text-center mt-4">
						<p class="font-body-md text-slate-400 text-sm">
							Zaten hesabın var mı? <a class="text-[#a78bfa] hover:text-white hover:underline hover:brightness-110 transition-all cursor-pointer font-medium" href="/login">Giriş yap</a>
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</Layout>

<script>
	// Particle Network Animation
	const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement;
	if (canvas) {
		const ctx = canvas.getContext('2d')!;
		let particles: any[] = [];
		let w: number, h: number;

		const init = () => {
			w = canvas.width = canvas.parentElement!.offsetWidth;
			h = canvas.height = canvas.parentElement!.offsetHeight;
			particles = [];
			for (let i = 0; i < 50; i++) {
				particles.push({
					x: Math.random() * w,
					y: Math.random() * h,
					vx: (Math.random() - 0.5) * 0.5,
					vy: (Math.random() - 0.5) * 0.5,
					radius: Math.random() * 1.5 + 0.5
				});
			}
		};

		const animate = () => {
			ctx.clearRect(0, 0, w, h);
			ctx.fillStyle = 'rgba(124, 92, 252, 1)'; 
			
			particles.forEach(p => {
				p.x += p.vx;
				p.y += p.vy;

				if (p.x < 0 || p.x > w) p.vx *= -1;
				if (p.y < 0 || p.y > h) p.vy *= -1;

				ctx.beginPath();
				ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
				ctx.fill();
			});

			ctx.strokeStyle = 'rgba(124, 92, 252, 0.2)';
			for (let i = 0; i < particles.length; i++) {
				for (let j = i + 1; j < particles.length; j++) {
					const dx = particles[i].x - particles[j].x;
					const dy = particles[i].y - particles[j].y;
					const dist = Math.sqrt(dx * dx + dy * dy);

					if (dist < 150) {
						ctx.beginPath();
						ctx.moveTo(particles[i].x, particles[i].y);
						ctx.lineTo(particles[j].x, particles[j].y);
						ctx.stroke();
					}
				}
			}
			requestAnimationFrame(animate);
		};

		window.addEventListener('resize', init);
		init();
		animate();
	}

	// Password Strength Checker
	const passwordInput = document.getElementById('password') as HTMLInputElement;
	passwordInput?.addEventListener('input', (e) => {
		const password = (e.target as HTMLInputElement).value;
		const strength1 = document.getElementById('strength-1')!;
		const strength2 = document.getElementById('strength-2')!;
		const strength3 = document.getElementById('strength-3')!;
		const strengthText = document.getElementById('strength-text')!;

		if (!password) {
			strength1.className = 'flex-1 rounded-full bg-[#2a2a4a] transition-colors duration-300';
			strength2.className = 'flex-1 rounded-full bg-[#2a2a4a] transition-colors duration-300';
			strength3.className = 'flex-1 rounded-full bg-[#2a2a4a] transition-colors duration-300';
			strengthText.innerText = 'Şifre gücü';
			strengthText.className = 'text-xs text-[#6b6b9a] mt-1';
			return;
		}

		let strength = 0;
		if (password.length > 5) strength += 1;
		if (password.match(/[a-z]/) && password.match(/[A-Z]/)) strength += 1;
		if (password.match(/\d/) || password.match(/[^a-zA-Z\d]/)) strength += 1;

		if (strength === 1) {
			strength1.className = 'flex-1 rounded-full bg-red-500 transition-colors duration-300';
			strength2.className = 'flex-1 rounded-full bg-[#2a2a4a] transition-colors duration-300';
			strength3.className = 'flex-1 rounded-full bg-[#2a2a4a] transition-colors duration-300';
			strengthText.innerText = 'Zayıf';
			strengthText.className = 'text-xs text-red-500 mt-1';
		} else if (strength === 2) {
			strength1.className = 'flex-1 rounded-full bg-yellow-500 transition-colors duration-300';
			strength2.className = 'flex-1 rounded-full bg-yellow-500 transition-colors duration-300';
			strength3.className = 'flex-1 rounded-full bg-[#2a2a4a] transition-colors duration-300';
			strengthText.innerText = 'Orta';
			strengthText.className = 'text-xs text-yellow-500 mt-1';
		} else if (strength === 3) {
			strength1.className = 'flex-1 rounded-full bg-green-500 transition-colors duration-300';
			strength2.className = 'flex-1 rounded-full bg-green-500 transition-colors duration-300';
			strength3.className = 'flex-1 rounded-full bg-green-500 transition-colors duration-300';
			strengthText.innerText = 'Güçlü';
			strengthText.className = 'text-xs text-green-500 mt-1';
		}
	});

	// Clear passwords on window load to prevent browser autofill
	window.addEventListener('DOMContentLoaded', () => {
		const passwordInput = document.getElementById('password') as HTMLInputElement;
		const confirmPasswordInput = document.getElementById('confirm_password') as HTMLInputElement;
		if (passwordInput) passwordInput.value = '';
		if (confirmPasswordInput) confirmPasswordInput.value = '';
	});

	// Toggle Password Visibility
	const togglePasswordBtn = document.getElementById('toggle-password');
	togglePasswordBtn?.addEventListener('click', () => {
		const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
		passwordInput.setAttribute('type', type);
		const icon = togglePasswordBtn.querySelector('span');
		if (icon) {
			icon.textContent = type === 'password' ? 'visibility' : 'visibility_off';
		}
	});

	const confirmPasswordInput = document.getElementById('confirm_password') as HTMLInputElement;
	const toggleConfirmPasswordBtn = document.getElementById('toggle-confirm-password');
	toggleConfirmPasswordBtn?.addEventListener('click', () => {
		const type = confirmPasswordInput.getAttribute('type') === 'password' ? 'text' : 'password';
		confirmPasswordInput.setAttribute('type', type);
		const icon = toggleConfirmPasswordBtn.querySelector('span');
		if (icon) {
			icon.textContent = type === 'password' ? 'visibility' : 'visibility_off';
		}
	});

	// Handle Submit
	const form = document.getElementById('register-form') as HTMLFormElement;
	const errorFeedback = document.getElementById('error-feedback') as HTMLDivElement;

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();

		const rawEmail = (document.getElementById('email') as HTMLInputElement).value;
		const email = rawEmail.trim().toLowerCase();
		const password = passwordInput.value;
		const confirmPassword = confirmPasswordInput.value;
		const termsChecked = (document.getElementById('terms') as HTMLInputElement).checked;
		const rememberMeChecked = (document.getElementById('remember_me') as HTMLInputElement).checked;

		errorFeedback.classList.add('hidden');
		errorFeedback.textContent = '';

		// E-posta regex kontrolü
		const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
		if (!emailRegex.test(email)) {
			errorFeedback.classList.remove('hidden');
			errorFeedback.textContent = '[Hata]: Geçersiz e-posta formatı.';
			return;
		}

		// Şifre uzunluk kontrolü
		if (password.length < 6) {
			errorFeedback.classList.remove('hidden');
			errorFeedback.textContent = '[Hata]: Şifre en az 6 karakter olmalıdır.';
			return;
		}

		// Şifre boşluk kontrolü
		if (password.includes(' ')) {
			errorFeedback.classList.remove('hidden');
			errorFeedback.textContent = '[Hata]: Şifre boşluk karakteri içeremez.';
			return;
		}

		if (password !== confirmPassword) {
			errorFeedback.classList.remove('hidden');
			errorFeedback.textContent = '[Hata]: Şifreler eşleşmiyor.';
			return;
		}

		if (!termsChecked) {
			errorFeedback.classList.remove('hidden');
			errorFeedback.textContent = '[Hata]: Lütfen kullanım şartlarını kabul edin.';
			return;
		}

		try {
			// Proxy yönlendirmesi: /api/* → backend :5000 (vite proxy)
			const response = await fetch('/api/auth/register', {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
				},
				body: JSON.stringify({ email, password }),
				credentials: 'include'
			});

			const data = await response.json();

			if (!response.ok) {
				throw new Error(data.message || 'Kayıt işlemi başarısız.');
			}

			// Store or clear remembered email based on the checkbox
			if (rememberMeChecked) {
				localStorage.setItem('remembered_email', email);
			} else {
				localStorage.removeItem('remembered_email');
			}

			// Redirect on success
			window.location.href = '/login';

		} catch (error: any) {
			errorFeedback.classList.remove('hidden');
			errorFeedback.textContent = `[Hata]: ${error.message}`;
		}
	});
</script>

<style>
	/* Particle Canvas Style */
	#particle-canvas {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		pointer-events: none;
	}

	/* Checkbox Style */
	.custom-checkbox:checked {
		background-color: #7c5cfc;
		border-color: #7c5cfc;
	}
	.custom-checkbox:checked::after {
		content: '';
		position: absolute;
		left: 6px;
		top: 3px;
		width: 5px;
		height: 10px;
		border: solid white;
		border-width: 0 2px 2px 0;
		transform: rotate(45deg);
	}

	/* Flow Animation */
	@keyframes flowFloat {
		0% { transform: translateY(0px); opacity: 0.08; }
		50% { transform: translateY(-6px); opacity: 0.12; }
		100% { transform: translateY(0px); opacity: 0.08; }
	}
	.animate-flow {
		animation: flowFloat 4s ease-in-out infinite;
	}
</style>

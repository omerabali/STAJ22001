---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Beacon - Login" theme="theme-login">
	<div class="theme-login bg-[#0d0d1a] text-on-surface antialiased min-h-screen flex flex-col md:flex-row font-body-md overflow-hidden">
		<!-- Left Side: Atmosphere -->
<div class="hidden md:flex flex-col w-1/2 relative p-margin-desktop overflow-hidden border-r border-white/5 justify-center min-h-screen">
<!-- Background Glows -->
<div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
<div class="absolute top-[20%] left-[10%] w-[400px] h-[400px] bg-[#7c5cfc]/20 rounded-full blur-[100px] animate-glow-1"></div>
<div class="absolute bottom-[20%] right-[10%] w-[500px] h-[500px] bg-blue-600/10 rounded-full blur-[120px] animate-glow-2"></div>
</div>
<!-- Floating CV Cloud -->
<div class="absolute inset-0 z-0 pointer-events-none opacity-60">
<!-- Card 1 -->
<div class="absolute top-[15%] right-[10%] w-64 p-4 rounded-xl cv-card animate-float-1">
<div class="flex items-center gap-3 mb-3">
<div class="w-10 h-10 rounded-full bg-surface-container-high/80"></div>
<div class="flex-1 space-y-2">
<div class="h-2 w-3/4 bg-surface-container-highest rounded"></div>
<div class="h-2 w-1/2 bg-surface-container-highest rounded"></div>
</div>
<svg class="text-brand-accent" fill="none" height="20" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg"><path d="M20 6 9 17l-5-5"></path></svg>
</div>
<div class="space-y-2">
<div class="h-1.5 w-full bg-surface-container-high/60 rounded"></div>
<div class="h-1.5 w-5/6 bg-surface-container-high/60 rounded"></div>
<div class="h-1.5 w-4/6 bg-surface-container-high/60 rounded"></div>
</div>
</div>
<!-- Card 2 -->
<div class="absolute top-[45%] right-[25%] w-56 p-3 rounded-xl cv-card animate-float-2">
<div class="flex items-center gap-3 mb-3">
<div class="w-8 h-8 rounded-full bg-surface-container-high/80"></div>
<div class="flex-1 space-y-1.5">
<div class="h-1.5 w-full bg-surface-container-highest rounded"></div>
<div class="h-1.5 w-2/3 bg-surface-container-highest rounded"></div>
</div>
<svg class="text-brand-accent" fill="none" height="16" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="16" xmlns="http://www.w3.org/2000/svg"><path d="M20 6 9 17l-5-5"></path></svg>
</div>
<div class="space-y-1.5">
<div class="h-1 w-full bg-surface-container-high/60 rounded"></div>
<div class="h-1 w-full bg-surface-container-high/60 rounded"></div>
</div>
</div>
<!-- Card 3 -->
<div class="absolute bottom-[20%] right-[15%] w-72 p-4 rounded-xl cv-card animate-float-3">
<div class="flex items-center gap-3 mb-3">
<div class="w-12 h-12 rounded-full bg-surface-container-high/80"></div>
<div class="flex-1 space-y-2">
<div class="h-2 w-4/5 bg-surface-container-highest rounded"></div>
<div class="h-2 w-3/5 bg-surface-container-highest rounded"></div>
</div>
<svg class="text-brand-accent" fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="24" xmlns="http://www.w3.org/2000/svg"><path d="M20 6 9 17l-5-5"></path></svg>
</div>
<div class="space-y-2">
<div class="h-1.5 w-full bg-surface-container-high/60 rounded"></div>
<div class="h-1.5 w-11/12 bg-surface-container-high/60 rounded"></div>
<div class="h-1.5 w-3/4 bg-surface-container-high/60 rounded"></div>
</div>
</div>
<!-- Card 4 -->
<div class="absolute top-[60%] left-[10%] w-48 p-3 rounded-xl cv-card animate-float-4 opacity-70">
<div class="flex items-center gap-2 mb-2">
<div class="w-8 h-8 rounded-full bg-surface-container-high/80"></div>
<div class="flex-1 space-y-1.5">
<div class="h-1.5 w-full bg-surface-container-highest rounded"></div>
</div>
<svg class="text-brand-accent" fill="none" height="16" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="16" xmlns="http://www.w3.org/2000/svg"><path d="M20 6 9 17l-5-5"></path></svg>
</div>
<div class="space-y-1.5">
<div class="h-1 w-full bg-surface-container-high/60 rounded"></div>
<div class="h-1 w-4/5 bg-surface-container-high/60 rounded"></div>
</div>
</div>
<!-- Card 5 -->
<div class="absolute bottom-[10%] left-[25%] w-60 p-4 rounded-xl cv-card animate-float-5">
<div class="flex items-center gap-3 mb-3">
<div class="w-10 h-10 rounded-full bg-surface-container-high/80"></div>
<div class="flex-1 space-y-2">
<div class="h-2 w-2/3 bg-surface-container-highest rounded"></div>
<div class="h-2 w-1/2 bg-surface-container-highest rounded"></div>
</div>
<svg class="text-brand-accent" fill="none" height="20" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg"><path d="M20 6 9 17l-5-5"></path></svg>
</div>
<div class="space-y-2">
<div class="h-1.5 w-full bg-surface-container-high/60 rounded"></div>
<div class="h-1.5 w-5/6 bg-surface-container-high/60 rounded"></div>
</div>
</div>
</div>
<!-- Overlay Content -->
<div class="relative z-10 flex flex-col">
<div class="absolute top-0 left-0 -mt-24">
<div class="font-headline-lg text-headline-lg font-bold tracking-tight text-on-surface flex items-center">
					<img src="/beacon.png" alt="Beacon Logo" class="h-8 w-auto object-contain" />
                    Beacon<span class="text-brand-accent ml-1">•</span>
</div>
</div>
<div class="max-w-[480px]">
<h1 class="font-display-lg text-display-lg text-on-surface mb-6 leading-tight">
                    Profesyonel profilleri anlamanın <br> daha iyi bir yolu.
                </h1>
<p class="font-body-lg text-xl text-on-surface/90 mb-8 leading-[1.8] max-w-[420px]">
                    CV’leri saniyeler içinde analiz edin, adayları akıllıca eşleştirin ve işe alım sürecinizi hızlandırın.
                </p>
<ul class="space-y-5 font-body-lg text-on-surface/90">
<li class="flex items-center gap-3">
<svg aria-hidden="true" class="lucide lucide-brain w-6 h-6 text-brand-accent" data-lucide="brain" fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="24" xmlns="http://www.w3.org/2000/svg"><path d="M12 18V5"></path><path d="M15 13a4.17 4.17 0 0 1-3-4 4.17 4.17 0 0 1-3 4"></path><path d="M17.598 6.5A3 3 0 1 0 12 5a3 3 0 1 0-5.598 1.5"></path></svg>
</li>
</ul>
</div>
</div>
</div>
<!-- Right Side: Login Form -->
<div class="w-full md:w-1/2 flex items-center justify-center p-6 sm:p-12 min-h-screen relative z-10">
<div class="w-full max-w-md space-y-8">
<div>
<h2 class="font-headline-md text-headline-md text-white mb-2">Tekrar hoş geldin</h2>
<p class="font-body-md text-on-surface-variant">Devam etmek için hesabına giriş yap.</p>
</div>
<div id="error-feedback" class="hidden w-full bg-red-950/40 border border-red-500/30 text-red-200 text-xs font-mono p-3 rounded-lg mb-4"></div>
<form id="login-form" class="space-y-6">
<div>
<label class="block text-sm font-medium text-on-surface mb-2" for="email">E-posta</label>
<input class="w-full bg-transparent border border-surface-variant rounded-lg px-4 py-3 text-white placeholder-on-surface-variant/50 input-glow focus:ring-0" id="email" name="email" placeholder="ornek@email.com" type="email" required>
</div>
<div>
<div class="flex items-center justify-between mb-2">
<label class="block text-sm font-medium text-on-surface" for="password">Şifre</label>
<a class="text-sm text-brand-accent hover:text-white transition-colors" href="/register">Şifremi unuttum</a>
</div>
<div class="relative">
<input class="w-full bg-transparent border border-surface-variant rounded-lg px-4 py-3 text-white placeholder-on-surface-variant/50 input-glow focus:ring-0" id="password" name="password" placeholder="••••••••" type="password" required>
<button class="absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-white transition-colors" type="button" id="toggle-password">
<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
</button>
</div>
</div>
<button class="w-full bg-[#7c5cfc] text-white font-medium py-3 px-4 rounded-lg btn-glow mt-2" type="submit">
                    Giriş Yap
                </button>
</form>
<div class="text-center mt-6">
<p class="text-on-surface-variant">Hesabın yok mu? <a class="text-[#a78bfa] hover:text-white transition-colors font-medium" href="/register">Kayıt ol</a></p>
</div>
<div class="absolute bottom-8 left-0 right-0 text-center text-sm text-on-surface-variant/60 flex items-center justify-center gap-2">
<span class="">🔒</span> Verileriniz uçtan uca şifrelenmektedir
            </div>
</div>
</div>
	</div>
</Layout>

<script>
	// Check for remembered email on DOMContentLoaded
	window.addEventListener('DOMContentLoaded', () => {
		const emailInput = document.getElementById('email') as HTMLInputElement;
		const rememberedEmail = localStorage.getItem('remembered_email');
		if (emailInput && rememberedEmail) {
			emailInput.value = rememberedEmail;
		}
	});

	// Toggle Password Visibility
	const togglePasswordBtn = document.getElementById('toggle-password');
	const passwordInput = document.getElementById('password') as HTMLInputElement;
	togglePasswordBtn?.addEventListener('click', () => {
		if (passwordInput.type === 'password') {
			passwordInput.type = 'text';
		} else {
			passwordInput.type = 'password';
		}
	});

	// Handle Submit
	const form = document.getElementById('login-form') as HTMLFormElement;
	const errorFeedback = document.getElementById('error-feedback') as HTMLDivElement;

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		
		const rawEmail = (document.getElementById('email') as HTMLInputElement).value;
		const email = rawEmail.trim().toLowerCase();
		const password = (document.getElementById('password') as HTMLInputElement).value;

		errorFeedback.classList.add('hidden');
		errorFeedback.textContent = '';

		try {
			// Proxy yönlendirmesi: /api/* → backend :5000 (vite proxy)
			const response = await fetch('/api/auth/login', {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
				},
				body: JSON.stringify({ email, password }),
				credentials: 'include'
			});

			const data = await response.json();

			if (!response.ok) {
				throw new Error(data.message || 'Kimlik doğrulama başarısız.');
			}

			// Redirect on success
			if (data.user && data.user.role === 'ADMIN') {
				window.location.href = '/admin/dashboard';
			} else {
				window.location.href = '/dashboard';
			}

		} catch (error: any) {
			errorFeedback.classList.remove('hidden');
			errorFeedback.textContent = `[Hata]: ${error.message}`;
		}
	});
</script>

<style>
	/* Custom styles specifically for Login atmosphere */
	.bg-gradient-custom {
		background: radial-gradient(circle at 50% 100%, rgba(79, 49, 156, 0.4) 0%, #0d0d1a 50%, #13132b 100%);
	}
	.btn-glow {
		transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}
	.btn-glow:hover {
		transform: scale(1.02);
		box-shadow: 0 8px 25px rgba(124, 92, 252, 0.4);
	}
	.input-glow {
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}
	.input-glow:focus {
		border-color: #7c5cfc;
		box-shadow: 0 0 0 1px #7c5cfc, 0 0 15px rgba(124, 92, 252, 0.25);
		outline: none;
	}
	
	/* Floating CV Cloud Animations */
	@keyframes float-1 {
		0%, 100% { transform: translateY(0) rotate(-2deg); }
		50% { transform: translateY(-20px) rotate(1deg); }
	}
	@keyframes float-2 {
		0%, 100% { transform: translateY(0) rotate(1deg); }
		50% { transform: translateY(-25px) rotate(-1deg); }
	}
	@keyframes float-3 {
		0%, 100% { transform: translateY(0) rotate(-1deg); }
		50% { transform: translateY(-15px) rotate(2deg); }
	}
	@keyframes glow-rotate {
		0% { transform: rotate(0deg) scale(1); }
		50% { transform: rotate(180deg) scale(1.1); }
		100% { transform: rotate(360deg) scale(1); }
	}
	
	.animate-float-1 { animation: float-1 7s ease-in-out infinite; }
	.animate-float-2 { animation: float-2 8s ease-in-out infinite 1s; }
	.animate-float-3 { animation: float-3 6s ease-in-out infinite 2s; }
	.animate-float-4 { animation: float-1 9s ease-in-out infinite 0.5s; }
	.animate-float-5 { animation: float-2 7.5s ease-in-out infinite 1.5s; }
	
	.animate-glow-1 { animation: glow-rotate 25s linear infinite; }
	.animate-glow-2 { animation: glow-rotate 30s linear infinite reverse; }
	
	.cv-card {
		background: rgba(255, 255, 255, 0.02);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		border: 1px solid rgba(124, 92, 252, 0.15);
		box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.5);
	}
</style>

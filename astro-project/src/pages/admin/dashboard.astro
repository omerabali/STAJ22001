---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Beacon AI - Admin Dashboard">
  <!-- Top Header -->
  <header class="mb-8">
    <h2 class="font-headline-md text-headline-md font-bold mb-2">Dashboard</h2>
    <p class="font-body-md text-body-md text-on-surface-variant">Beacon genel platform durumunu buradan takip edebilirsiniz.</p>
  </header>

  <!-- Stats Row -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-surface-container-highest border border-outline-variant rounded-xl p-6 flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_25px_rgba(124,58,237,0.15)] group">
      <div class="flex items-center justify-between mb-2">
        <span class="font-label-md text-label-md text-on-surface-variant uppercase group-hover:text-primary transition-colors duration-300">Aktif Adaylar</span>
        <span class="material-symbols-outlined text-primary opacity-70 group-hover:scale-110 group-hover:opacity-100 transition-all duration-300">group</span>
      </div>
      <span id="stat-candidates" class="font-display-lg text-display-lg text-[#7c5cfc] font-bold">...</span>
    </div>
    
    <div class="bg-surface-container-highest border border-outline-variant rounded-xl p-6 flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_25px_rgba(124,58,237,0.15)] group">
      <div class="flex items-center justify-between mb-2">
        <span class="font-label-md text-label-md text-on-surface-variant uppercase group-hover:text-primary transition-colors duration-300">Toplam Yöneticiler</span>
        <span class="material-symbols-outlined text-primary opacity-70 group-hover:scale-110 group-hover:opacity-100 transition-all duration-300">admin_panel_settings</span>
      </div>
      <span id="stat-admins" class="font-display-lg text-display-lg text-[#7c5cfc] font-bold">...</span>
    </div>
    
    <div class="bg-surface-container-highest border border-outline-variant rounded-xl p-6 flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_25px_rgba(124,58,237,0.15)] group">
      <div class="flex items-center justify-between mb-2">
        <span class="font-label-md text-label-md text-on-surface-variant uppercase group-hover:text-primary transition-colors duration-300">Bugün Kaydolanlar</span>
        <span class="material-symbols-outlined text-primary opacity-70 group-hover:scale-110 group-hover:opacity-100 transition-all duration-300">person_add</span>
      </div>
      <span id="stat-new-users" class="font-display-lg text-display-lg text-[#7c5cfc] font-bold">...</span>
    </div>
  </div>
  
  <div class="bg-surface-container-lowest border border-outline-variant p-8 rounded-xl flex flex-col items-center justify-center min-h-[300px] relative overflow-hidden group">
      <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
      <span class="material-symbols-outlined text-6xl text-primary/30 mb-4 group-hover:scale-110 transition-transform duration-500">monitoring</span>
      <p class="text-on-surface-variant font-body-lg text-center max-w-md relative z-10">
        Daha detaylı grafikler ve analizler <b>Raporlar</b> sekmesinde yer almaktadır.
      </p>
      <a href="/admin/reports" class="mt-6 border border-primary text-primary hover:bg-primary hover:text-white px-6 py-2 rounded-lg font-label-md transition-all duration-300 relative z-10 active:scale-95">
        Raporlara Git
      </a>
  </div>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", async () => {
      try {
        const res = await fetch('/api/admin/stats');
        if (res.ok) {
          const data = await res.json();
          document.getElementById('stat-candidates').textContent = data.candidates || 0;
          document.getElementById('stat-admins').textContent = data.admins || 0;
          document.getElementById('stat-new-users').textContent = data.newUsersToday || 0;
        } else {
          console.error("Stats fetch error:", res.status);
          document.getElementById('stat-candidates').textContent = 'Hata';
          document.getElementById('stat-admins').textContent = 'Hata';
          document.getElementById('stat-new-users').textContent = 'Hata';
        }
      } catch (error) {
        console.error("Sunucu bağlantı hatası:", error);
      }
    });
  </script>
</AdminLayout>
---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Beacon - Admin Dashboard">
  <!-- Top Header -->
  <header class="mb-8">
    <h2 class="font-headline-md text-headline-md font-bold mb-2 text-[#1b1c1a]">Dashboard</h2>
    <p class="font-body-md text-body-md text-[#8a8580]">Platform genel analiz ve durum raporunu anlık olarak buradan takip edebilirsiniz.</p>
  </header>

  <!-- Stats Row -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <!-- Stat Card 1 -->
    <div class="bg-white rounded-[10px] p-6 shadow-sm border border-[#ddd9d3] border-l-[3px] border-l-[#14422f] hover:shadow-md transition-all duration-200 cursor-pointer group">
      <div class="flex justify-between items-start mb-4">
        <div class="flex flex-col">
          <span class="font-label-md text-label-md text-[#8a8580] mb-1">Aktif Adaylar</span>
          <span id="stat-candidates" class="font-display-lg text-display-lg text-[#1b1c1a] font-light tracking-tight group-hover:text-[#14422f] transition-colors">...</span>
        </div>
        <div class="w-10 h-10 rounded-full bg-[#14422f]/10 flex items-center justify-center text-[#14422f]">
          <span class="material-symbols-outlined">person_search</span>
        </div>
      </div>
      <div class="flex items-center gap-2 mt-4">
        <span class="flex items-center text-[#14422f] font-semibold text-xs bg-[#14422f]/10 px-2 py-0.5 rounded">
          <span class="material-symbols-outlined text-[14px] mr-1">trending_up</span>
          +12%
        </span>
        <span class="text-xs text-[#8a8580] font-medium">geçen haftaya göre</span>
      </div>
    </div>
    
    <!-- Stat Card 2 -->
    <div class="bg-white rounded-[10px] p-6 shadow-sm border border-[#ddd9d3] hover:shadow-md transition-all duration-200 cursor-pointer group">
      <div class="flex justify-between items-start mb-4">
        <div class="flex flex-col">
          <span class="font-label-md text-label-md text-[#8a8580] mb-1">Toplam Yöneticiler</span>
          <span id="stat-admins" class="font-display-lg text-display-lg text-[#1b1c1a] font-light tracking-tight group-hover:text-[#14422f] transition-colors">...</span>
        </div>
        <div class="w-10 h-10 rounded-full bg-[#f5f4f0] flex items-center justify-center text-[#8a8580]">
          <span class="material-symbols-outlined">badge</span>
        </div>
      </div>
      <div class="flex items-center gap-2 mt-4">
        <span class="text-xs text-[#8a8580] font-medium">Sistemde kayıtlı yetkili kullanıcılar</span>
      </div>
    </div>
    
    <!-- Stat Card 3 -->
    <div class="bg-white rounded-[10px] p-6 shadow-sm border border-[#ddd9d3] hover:shadow-md transition-all duration-200 cursor-pointer group">
      <div class="flex justify-between items-start mb-4">
        <div class="flex flex-col">
          <span class="font-label-md text-label-md text-[#8a8580] mb-1">Bugün Kayıtlar</span>
          <span id="stat-new-users" class="font-display-lg text-display-lg text-[#1b1c1a] font-light tracking-tight group-hover:text-[#14422f] transition-colors">...</span>
        </div>
        <div class="w-10 h-10 rounded-full bg-[#f5f4f0] flex items-center justify-center text-[#8a8580]">
          <span class="material-symbols-outlined">how_to_reg</span>
        </div>
      </div>
      <div class="flex items-center gap-2 mt-4">
        <span class="flex items-center text-[#14422f] font-semibold text-xs bg-[#14422f]/10 px-2 py-0.5 rounded">
          <span class="material-symbols-outlined text-[14px] mr-1">trending_up</span>
          +4
        </span>
        <span class="text-xs text-[#8a8580] font-medium">düne göre yeni kayıt</span>
      </div>
    </div>
  </div>
  
  <!-- Info Card -->
  <div class="bg-white p-8 rounded-[10px] border border-[#ddd9d3] shadow-sm flex flex-col items-center justify-center min-h-[300px] text-center">
    <span class="material-symbols-outlined text-6xl text-[#14422f]/20 mb-4">monitoring</span>
    <p class="text-[#8a8580] text-sm font-medium leading-relaxed" style="max-width: 440px; text-align: center;">
      Detaylı ATS başarı oranları, yetenek bulutları ve günlük kayıt istatistikleri <b>Platform Raporları</b> sekmesinde yer almaktadır.
    </p>
    <a href="/admin/reports" class="btn-primary mt-6 px-6 py-3 font-semibold text-sm shadow-sm inline-flex items-center gap-2">
      <span class="material-symbols-outlined text-sm">assessment</span> Raporlara Git
    </a>
  </div>

  <script is:inline>
    async function loadStats() {
      const fetcher = async () => {
        const res = await fetch('/api/admin/stats');
        if (!res.ok) throw new Error("Fetch stats error");
        return res.json();
      };

      const render = (data) => {
        document.getElementById('stat-candidates').textContent = data.candidates || 0;
        document.getElementById('stat-admins').textContent = data.admins || 0;
        document.getElementById('stat-new-users').textContent = data.newUsersToday || 0;
      };

      if (window.__swrCache) {
        window.__swrCache.query('dashboard-stats', fetcher, render, 30000);
      } else {
        fetcher().then(render).catch(() => {
          document.getElementById('stat-candidates').textContent = 'Hata';
          document.getElementById('stat-admins').textContent = 'Hata';
          document.getElementById('stat-new-users').textContent = 'Hata';
        });
      }
    }

    document.addEventListener("astro:page-load", () => {
      if (document.getElementById('stat-candidates')) {
        loadStats();
      }
    });
  </script>
</AdminLayout>
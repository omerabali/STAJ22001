---
import AdminLayout from '../../layouts/AdminLayout.astro';
const { user } = Astro.locals;
---

<AdminLayout title="Beacon - Kullanıcı Yönetimi">
  <div id="users-page-container" data-current-user-id={user?.id}></div>

  <!-- Top Header -->
  <header class="mb-8">
    <h2 class="font-headline-md text-headline-md font-bold mb-2 text-[#1b1c1a]">Kullanıcı Yönetimi</h2>
    <p class="font-body-md text-body-md text-[#8a8580]">Sistemdeki kullanıcıları listeleyin ve rollerini yönetin.</p>
  </header>

  <!-- Stats Row -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <!-- Stat 1 -->
    <div class="bg-white border border-[#ddd9d3] rounded-[10px] p-6 shadow-sm hover:shadow-md transition-all duration-200">
      <span class="font-label-md text-label-md text-[#8a8580] mb-2 uppercase block font-semibold">Toplam Kullanıcı</span>
      <span id="stat-total" class="font-display-lg text-display-lg text-[#14422f] font-light">-</span>
    </div>
    <!-- Stat 2 -->
    <div class="bg-white border border-[#ddd9d3] rounded-[10px] p-6 shadow-sm hover:shadow-md transition-all duration-200">
      <span class="font-label-md text-label-md text-[#8a8580] mb-2 uppercase block font-semibold">Aday</span>
      <span id="stat-candidates" class="font-display-lg text-display-lg text-[#1b1c1a] font-light">-</span>
    </div>
    <!-- Stat 3 -->
    <div class="bg-white border border-[#ddd9d3] rounded-[10px] p-6 shadow-sm hover:shadow-md transition-all duration-200">
      <span class="font-label-md text-label-md text-[#8a8580] mb-2 uppercase block font-semibold">Yönetici</span>
      <span id="stat-admins" class="font-display-lg text-display-lg text-[#1b1c1a] font-light">-</span>
    </div>
  </div>

  <!-- Actions Bar -->
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
    <span id="total-text" class="font-body-sm text-body-sm text-[#8a8580] font-medium">Yükleniyor...</span>
    <div class="flex gap-4 w-full sm:w-auto">
      <div class="relative flex-1 sm:flex-initial">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-[#8a8580]" style="font-size: 20px;">search</span>
        <input id="user-search-input" class="bg-[#faf9f5] border border-[#ddd9d3] text-[#1b1c1a] rounded-[10px] pl-10 pr-4 py-2 focus:border-[#14422f] focus:ring-1 focus:ring-[#14422f] focus:outline-none font-body-sm text-sm w-full sm:w-64 transition-all" placeholder="Kullanıcı ara..." type="text"/>
      </div>
      <button onclick="fetchUsers()" class="flex items-center gap-2 border border-[#ddd9d3] text-[#1b1c1a] hover:bg-[#faf9f5] px-4 py-2 rounded-[10px] transition-colors font-label-md text-sm font-semibold bg-white shadow-sm">
        <span class="material-symbols-outlined text-sm">refresh</span>
        Yenile
      </button>
    </div>
  </div>

  <!-- User Table -->
  <div class="bg-white border border-[#ddd9d3] rounded-[10px] overflow-hidden shadow-sm">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-[#f5f4f0] text-[#8a8580] font-label-md text-xs uppercase tracking-wider border-b border-[#ddd9d3]">
          <th class="p-4 font-semibold">Kullanıcı</th>
          <th class="p-4 font-semibold">E-posta</th>
          <th class="p-4 font-semibold">Kayıt Tarihi</th>
          <th class="p-4 font-semibold">Rol</th>
          <th class="p-4 font-semibold text-right">Aksiyon</th>
        </tr>
      </thead>
      <tbody id="users-tbody" class="font-body-sm text-sm text-[#1b1c1a] divide-y divide-[#ddd9d3]">
        <tr>
          <td colspan="5" class="p-8 text-center text-[#8a8580] font-medium">Kullanıcılar yükleniyor...</td>
        </tr>
      </tbody>
    </table>
  </div>


  <script is:inline>
    // Make these globally accessible
    window.currentUserId = null;

    async function changeRole(userId, newRole) {
      if (!confirm(`Kullanıcı rolünü ${newRole} olarak değiştirmek istediğinize emin misiniz?`)) return;
      
      try {
        const res = await fetch(`/api/admin/users/${userId}/role`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ role: newRole })
        });
        
        const data = await res.json();
        if (res.ok) {
          alert('Rol başarıyla güncellendi!');
          // Temizlemek/güncellemek için doğrudan cache'i temizleyip yeniden çekelim
          if (window.__swrCache) window.__swrCache.invalidate('users');
          fetchUsers(); 
        } else {
          alert('Hata: ' + (data.message || 'Bilinmeyen bir hata oluştu.'));
        }
      } catch (err) {
        alert('Sunucuya bağlanılamadı.');
      }
    }

    async function fetchUsers() {
      const tbody = document.getElementById('users-tbody');

      // Read currentUserId from SSR data attribute
      if (!window.currentUserId) {
        const container = document.getElementById('users-page-container');
        window.currentUserId = container ? container.dataset.currentUserId : null;
      }
      
      const fetcher = async () => {
        const res = await fetch('/api/admin/users');
        if (!res.ok) throw new Error("Fetch users error");
        return res.json();
      };

      const render = (data) => {
        const users = data.users || [];
        let candidates = 0;
        let admins = 0;

        const rowsHTML = users.map((user, index) => {
          if (user.role === 'ADMIN') admins++;
          if (user.role === 'CANDIDATE') candidates++;

          const date = new Date(user.createdAt).toLocaleDateString('tr-TR');
          const initials = (user.name || user.email).substring(0, 2).toUpperCase();
          const colors = ['bg-primary-container text-on-primary-container', 'bg-secondary-container text-on-secondary-container', 'bg-tertiary-container text-on-tertiary-container'];
          const colorClass = colors[index % colors.length];
          const isMe = window.currentUserId === user.id;

          return `
            <tr class="hover:bg-[#f5f4f0]/40 transition-colors duration-150 group">
              <td class="p-4">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-[#14422f]/10 text-[#14422f] flex items-center justify-center font-bold text-xs">${initials}</div>
                  <span class="font-bold text-[#1b1c1a] text-sm">${user.name || 'İsimsiz'}</span>
                  ${isMe ? '<span class="bg-[#faf9f5] border border-[#ddd9d3] text-[#1b1c1a] px-2 py-0.5 rounded text-xs ml-2 font-medium">Sen</span>' : ''}
                </div>
              </td>
              <td class="p-4 text-[#8a8580] font-medium">${user.email}</td>
              <td class="p-4 text-[#8a8580] font-medium">${date}</td>
              <td class="p-4">
                ${user.role === 'ADMIN' 
                  ? '<span class="bg-[#14422f] text-white px-2.5 py-1 rounded-[6px] font-bold text-xs">Yönetici</span>' 
                  : '<span class="bg-[#14422f]/10 text-[#14422f] px-2.5 py-1 rounded-[6px] font-semibold text-xs">Aday</span>'}
              </td>
              <td class="p-4 text-right">
                ${!isMe ? `
                  <button onclick="changeRole('${user.id}', '${user.role === 'ADMIN' ? 'CANDIDATE' : 'ADMIN'}')" class="px-3 py-1.5 border border-[#ddd9d3] rounded-[8px] bg-white text-[#1b1c1a] hover:border-[#14422f] hover:text-[#14422f] text-xs font-semibold transition-all shadow-sm opacity-0 group-hover:opacity-100 focus:opacity-100">
                    ${user.role === 'ADMIN' ? 'Aday Yap' : 'Yönetici Yap'}
                  </button>
                ` : '<span class="text-[#8a8580] text-xs font-medium">Yetki değiştirilemez</span>'}
              </td>
            </tr>
          `;
        }).join('');

        tbody.innerHTML = rowsHTML || '<tr><td colspan="5" class="p-8 text-center text-on-surface-variant">Hiç kullanıcı bulunamadı.</td></tr>';
        
        document.getElementById('stat-total').textContent = users.length;
        document.getElementById('stat-candidates').textContent = candidates;
        document.getElementById('stat-admins').textContent = admins;
        document.getElementById('total-text').textContent = `Toplam ${users.length} kullanıcı`;
      };

      if (window.__swrCache) {
        window.__swrCache.query('users', fetcher, render, 30000);
      } else {
        tbody.innerHTML = '<tr><td colspan="5" class="p-8 text-center text-on-surface-variant">Kullanıcılar yükleniyor...</td></tr>';
        fetcher().then(render).catch(() => {
          tbody.innerHTML = '<tr><td colspan="5" class="p-8 text-center text-red-400">Yükleme hatası</td></tr>';
        });
      }
    }

    // Sayfa yüklendiğinde veya SPA geçişi yapıldığında tetikle
    document.addEventListener("astro:page-load", () => {
      if (document.getElementById('users-tbody')) {
        fetchUsers();
      }
    });
  </script>
</AdminLayout>

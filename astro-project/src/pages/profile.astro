---
import UserLayout from '../layouts/UserLayout.astro';
---

<UserLayout title="Beacon AI - Dashboard" headerTitle="Aday Paneli">
  <!-- Hoş Geldin Banner -->
  <div class="mb-xl glass-card rounded-2xl p-6 flex items-center relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-brand-accent/5 to-transparent pointer-events-none"></div>
    <div class="flex items-center gap-4 relative z-10">
      <div class="w-12 h-12 rounded-xl bg-brand-accent/15 flex items-center justify-center shrink-0 border border-brand-accent/30">
        <span class="material-symbols-outlined text-brand-accent">waving_hand</span>
      </div>
      <div>
        <p class="text-brand-muted text-body-sm">Hoş geldiniz,</p>
        <h3 class="text-headline-sm font-bold text-brand-text" id="welcome-name">Kullanıcı</h3>
      </div>
    </div>
  </div>

  <div id="candidate-view" class="space-y-xl">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">
      
      <!-- Left side: CV Upload & History -->
      <div class="lg:col-span-7 flex flex-col gap-lg">
        
        <!-- CV Upload Card -->
        <div class="glass-card rounded-2xl p-6 flex flex-col relative overflow-hidden">
          <h3 class="text-xl font-semibold text-brand-text mb-2">Yeni CV Yükle</h3>
          <p class="text-brand-muted text-sm mb-6">CV'nizi PDF formatında yükleyerek yapay zeka ile saniyeler içinde yetenek analizi alabilirsiniz.</p>
          
          <!-- Dropzone -->
          <div class="dropzone-glow bg-brand-bg/50 rounded-2xl p-12 flex flex-col items-center justify-center cursor-pointer group relative overflow-hidden animate-fade-in" id="drop-zone">
            <div class="absolute inset-0 bg-brand-accent/5 opacity-0 group-hover:opacity-100 transition-opacity blur-xl"></div>
            <div class="upload-icon w-20 h-20 mb-5 rounded-full bg-brand-card border border-brand-border flex items-center justify-center group-hover:bg-brand-accent/10 group-hover:text-brand-accent group-hover:border-brand-accent/30 transition-all duration-300">
              <i class="fa-solid fa-cloud-arrow-up text-3xl text-brand-muted group-hover:text-brand-accent"></i>
            </div>
            <h4 class="text-brand-text font-semibold mb-2 text-lg text-center">Dosyayı sürükleyip bırakın veya seçin</h4>
            <p class="text-brand-muted text-sm text-center">Yalnızca PDF formatı desteklenir (Maks: 5MB)</p>
            <input type="file" id="cv-file-input" accept=".pdf" class="hidden" />
          </div>

          <div class="mt-md hidden" id="upload-progress-container">
            <div class="flex justify-between text-label-md font-medium text-brand-muted mb-xs">
              <span id="upload-status-text">Dosya yükleniyor...</span>
              <span id="upload-percent">0%</span>
            </div>
            <div class="w-full bg-brand-border h-2 rounded-full overflow-hidden">
              <div class="bg-brand-accent h-full w-0 transition-all duration-300" id="upload-progress-bar"></div>
            </div>
          </div>
        </div>

        <!-- My CV List -->
        <div class="glass-card rounded-2xl flex-1 flex flex-col overflow-hidden" id="my-analyses">
          <div class="p-6 border-b border-brand-border">
            <h3 class="text-xl font-semibold text-brand-text">Son Yüklemeler</h3>
          </div>
          <div class="overflow-x-auto custom-scrollbar">
            <table class="w-full text-left text-sm whitespace-nowrap">
              <thead class="text-xs text-brand-muted uppercase bg-brand-bg/80 border-y border-brand-border">
                <tr>
                  <th class="px-6 py-4 font-semibold rounded-tl-xl" scope="col">Belge Adı</th>
                  <th class="px-6 py-4 font-semibold" scope="col">Yükleme Tarihi</th>
                  <th class="px-6 py-4 font-semibold" scope="col">Analiz Durumu</th>
                  <th class="px-6 py-4 font-semibold text-center" scope="col">Uyum Skoru</th>
                  <th class="px-6 py-4 font-semibold text-right rounded-tr-xl" scope="col">İşlem</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-brand-border/50 text-brand-text" id="my-cvs-body">
                <tr>
                  <td colspan="5" class="px-6 py-4 text-center text-brand-muted">Yüklemeler sorgulanıyor...</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

      </div>

      <!-- Right side: AI Analysis Details -->
      <div class="lg:col-span-5">
        <div class="glass-card rounded-2xl h-full flex flex-col p-8 relative overflow-hidden min-h-[480px] lg:min-h-[580px]" id="analysis-detail-card">
          <!-- Background Glow Decoration -->
          <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 bg-brand-accent/5 rounded-full blur-3xl pointer-events-none"></div>

          <!-- Empty State (Initially Visible) -->
          <div class="text-center py-12 text-brand-muted flex flex-col items-center justify-center h-full space-y-6 my-auto relative z-10" id="no-analysis-state">
            <!-- Atmospheric Background Grid -->
            <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle at center, rgba(56,189,248,0.03) 1px, transparent 1px); background-size: 24px 24px;"></div>
            
            <div class="w-48 h-48 mb-6 relative flex items-center justify-center animate-float">
              <!-- Glow backdrops -->
              <div class="absolute w-40 h-40 bg-brand-accent/10 rounded-full blur-2xl mix-blend-screen animate-pulse-slow"></div>
              <div class="absolute w-44 h-44 border border-brand-accent/5 rounded-full animate-spin-slow"></div>
              
              <!-- Outer glowing ring -->
              <div class="w-36 h-36 rounded-full border border-brand-accent/20 bg-brand-card/50 flex items-center justify-center relative shadow-[inset_0_0_20px_rgba(56,189,248,0.1)]">
                <!-- Ping ring -->
                <div class="absolute inset-0 rounded-full border border-brand-accent/20 animate-ping opacity-40"></div>
                <!-- Magic sparkles icon -->
                <i class="fa-solid fa-wand-magic-sparkles text-brand-accent text-5xl drop-shadow-[0_0_15px_rgba(56,189,248,0.6)]"></i>
              </div>
            </div>
            <div class="text-center relative z-10 max-w-sm px-6">
              <h3 class="text-2xl font-bold text-brand-text mb-3">Analiz İçin Hazır</h3>
              <p class="text-sm text-brand-muted text-center leading-relaxed">Sol panelden bir özgeçmiş seçerek veya yeni bir dosya yükleyerek yapay zeka analizini anında başlatabilirsiniz.</p>
            </div>
          </div>

          <!-- Active Analysis State (Initially Hidden) -->
          <div class="hidden space-y-lg h-full flex flex-col relative z-10" id="active-analysis-state">
            <div class="flex items-center justify-between pb-md border-b border-brand-border shrink-0">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-brand-danger/10 flex items-center justify-center border border-brand-danger/20">
                  <i class="fa-solid fa-file-pdf text-brand-danger text-xl"></i>
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="text-lg font-bold text-brand-text truncate leading-tight max-w-[180px]" id="analysis-cv-name">Özgeçmiş</h3>
                  <div class="flex items-center gap-2 mt-0.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-brand-accent animate-pulse" id="analysis-dot"></span>
                    <span class="text-[10px] text-brand-accent font-bold tracking-widest uppercase">Yapay Zeka Analiz Raporu</span>
                  </div>
                </div>
              </div>
              <div id="analysis-status-indicator">
                <span class="material-symbols-outlined text-brand-success text-3xl">verified</span>
              </div>
            </div>

            <div id="analysis-content-area" class="space-y-lg flex flex-col h-full overflow-hidden">
              <!-- Dynamic content will be injected by JS -->
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</UserLayout>

<script is:inline>
  let activeInterval = null;
  let selectedCvId = null;

  const dateEl = document.getElementById('session-date');
  if (dateEl) {
    dateEl.textContent = new Date().toLocaleDateString('tr-TR', { 
      weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' 
    });
  }

  // Load active user session
  fetch('/api/auth/me').then(res => res.json()).then(data => {
    if(data.user) {
      document.getElementById('welcome-name').textContent = data.user.name || data.user.email.split('@')[0];
    }
  }).catch(console.error);

  // Delete CV handler
  window.deleteCV = async function(cvId) {
    if (!confirm('Bu özgeçmişi ve tüm ilişkili verileri silmek istediğinize emin misiniz?')) {
      return;
    }
    try {
      const res = await fetch(`/api/cv/${cvId}`, {
        method: 'DELETE'
      });
      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.message || 'Silme işlemi başarısız.');
      }
      
      if (selectedCvId === cvId) {
        selectedCvId = null;
        document.getElementById('no-analysis-state').classList.remove('hidden');
        document.getElementById('active-analysis-state').classList.add('hidden');
      }
      
      await loadCVList();
    } catch (err) {
      console.error(err);
      alert(err.message);
    }
  };

  // Load CV List and poll if PENDING/PROCESSING status is active
  async function loadCVList() {
    try {
      const res = await fetch('/api/cv/list');
      if (!res.ok) return;
      const data = await res.json();
      const tbody = document.getElementById('my-cvs-body');
      if (!tbody) return;

      if (!data.cvs || data.cvs.length === 0) {
        tbody.innerHTML = `
          <tr>
            <td colspan="5" class="p-lg text-center text-on-surface-variant">Henüz CV yüklemediniz. Aşağıdan yeni bir dosya seçebilirsiniz.</td>
          </tr>
        `;
        return;
      }

      tbody.innerHTML = '';
      let hasPendingOrProcessing = false;

      // Scan all CVs for pending status to control polling
      data.cvs.forEach(cv => {
        const latestAnalysis = cv.analyses && cv.analyses[0];
        const status = latestAnalysis ? latestAnalysis.status : 'PENDING';
        if (status === 'PENDING' || status === 'PROCESSING') {
          hasPendingOrProcessing = true;
        }
      });

      // Display only the latest 3 CVs on the Dashboard
      const cvsToShow = data.cvs.slice(0, 3);

      cvsToShow.forEach(cv => {
        const latestAnalysis = cv.analyses && cv.analyses[0];
        const status = latestAnalysis ? latestAnalysis.status : 'PENDING';
        const dateStr = new Date(cv.createdAt).toLocaleDateString('tr-TR');
        
        let statusBadge = '';
        if (status === 'PENDING') {
          statusBadge = `
            <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold bg-brand-warning/10 text-brand-warning border border-brand-warning/20">
              <span class="w-2 h-2 rounded-full bg-brand-warning animate-pulse"></span> Sırada
            </span>
          `;
        } else if (status === 'PROCESSING') {
          statusBadge = `
            <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold bg-brand-accent/10 text-brand-accent border border-brand-accent/20">
              <span class="w-2 h-2 rounded-full bg-brand-accent animate-spin"></span> İşleniyor...
            </span>
          `;
        } else if (status === 'COMPLETED') {
          statusBadge = `
            <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold bg-brand-successBg text-brand-success border border-brand-success/20 shadow-[0_0_10px_rgba(74,222,128,0.2)]">
              <span class="w-2 h-2 rounded-full bg-brand-success"></span> Hazır
            </span>
          `;
        } else {
          statusBadge = `
            <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold bg-brand-danger/10 text-brand-danger border border-brand-danger/20">
              <span class="w-2 h-2 rounded-full bg-brand-danger"></span> Hata
            </span>
          `;
        }

        const scoreStr = latestAnalysis && latestAnalysis.atsScore !== null 
          ? `<span class="font-bold text-brand-success">%${latestAnalysis.atsScore}</span>` 
          : `<span class="text-brand-muted">-</span>`;

        const tr = document.createElement('tr');
        tr.className = `table-row-hover group cursor-pointer ${selectedCvId === cv.id ? 'bg-white/8' : ''}`;
        tr.onclick = () => {
          selectedCvId = cv.id;
          const rows = tbody.querySelectorAll('tr');
          rows.forEach(r => r.classList.remove('bg-white/8'));
          tr.classList.add('bg-white/8');
          showAnalysisDetails(cv, latestAnalysis);
        };

        tr.innerHTML = `
          <td class="px-6 py-5">
            <div class="flex items-center gap-4">
              <i class="fa-regular fa-file-pdf text-brand-danger text-xl"></i>
              <span class="font-medium text-brand-text truncate max-w-[200px]">${cv.fileName}</span>
            </div>
          </td>
          <td class="px-6 py-5 text-brand-muted">${dateStr}</td>
          <td class="px-6 py-5">${statusBadge}</td>
          <td class="px-6 py-5 text-center">${scoreStr}</td>
          <td class="px-6 py-5 text-right" onclick="event.stopPropagation();">
            <button class="text-brand-muted hover:text-brand-danger p-2 rounded-lg hover:bg-brand-bg transition-colors" onclick="deleteCV('${cv.id}')" title="Sil">
              <i class="fa-regular fa-trash-can text-lg"></i>
            </button>
          </td>
        `;
        tbody.appendChild(tr);

        // Keep updating selected analysis details in real-time
        if (selectedCvId === cv.id) {
          showAnalysisDetails(cv, latestAnalysis);
        }
      });

      // Poll every 3 seconds if status is changing
      if (hasPendingOrProcessing) {
        if (!activeInterval) {
          activeInterval = setInterval(loadCVList, 3000);
        }
      } else {
        if (activeInterval) {
          clearInterval(activeInterval);
          activeInterval = null;
        }
      }
    } catch (err) {
      console.error("CV yükleme geçmişi alınamadı:", err);
    }
  }

  function showAnalysisDetails(cv, analysis) {
    const noState = document.getElementById('no-analysis-state');
    const activeState = document.getElementById('active-analysis-state');
    if (!noState || !activeState) return;

    noState.classList.add('hidden');
    activeState.classList.remove('hidden');

    document.getElementById('analysis-cv-name').textContent = cv.fileName;

    const statusIndicator = document.getElementById('analysis-status-indicator');
    const contentArea = document.getElementById('analysis-content-area');

    if (!analysis) return;

    const status = analysis.status;

    if (status === 'COMPLETED') {
      statusIndicator.innerHTML = `<span class="material-symbols-outlined text-brand-success text-3xl">verified</span>`;
      contentArea.classList.remove('hidden');

      if (analysis.atsScore === null) {
        // Day 13 completed state: text chunks successfully generated but AI scoring is not done
        const chunkHtml = cv.chunks && cv.chunks.length > 0 
          ? cv.chunks.map((chunk, idx) => {
              // Separate section header from content (content starts with [SECTION_NAME]\n)
              const firstLineBreak = chunk.content.indexOf('\n');
              const header = firstLineBreak !== -1 ? chunk.content.substring(0, firstLineBreak) : `PARÇA #${idx + 1}`;
              const body = firstLineBreak !== -1 ? chunk.content.substring(firstLineBreak + 1) : chunk.content;
              const wordCount = body.split(/\s+/).filter(w => w.length > 0).length;

              return `
                <div class="group bg-brand-bg/40 rounded-xl border-l-4 border-brand-accent p-5 hover:bg-brand-bg/60 transition-all text-left">
                  <div class="flex justify-between items-start mb-2">
                    <div>
                      <span class="text-[10px] font-bold text-brand-accent uppercase tracking-tighter">${header}</span>
                    </div>
                    <span class="text-[10px] font-mono text-brand-muted bg-brand-bg px-2 py-1 rounded">${wordCount} kelime</span>
                  </div>
                  <p class="text-xs text-brand-muted leading-relaxed font-sans whitespace-pre-wrap select-all max-h-[120px] overflow-y-auto pr-xs mt-xs">
                    ${body}
                  </p>
                </div>
              `;
            }).join('')
          : `<p class="text-xs text-brand-muted text-center py-md">Metin parçaları veritabanında bulunamadı.</p>`;

        const skillsHtml = Array.isArray(analysis.skills) && analysis.skills.length > 0
          ? analysis.skills.map(s => `
              <span class="px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-brand-accent text-xs font-semibold shadow-sm transform hover:scale-105 transition-transform cursor-default">
                ${s}
              </span>
            `).join('')
          : `<span class="text-xs text-brand-muted">Yetenek kelimeleri çıkarılamadı.</span>`;

        contentArea.innerHTML = `
          <div class="space-y-md flex flex-col h-full overflow-hidden">
            <!-- Skills Container -->
            <div class="space-y-sm shrink-0">
              <h4 class="text-[10px] font-bold text-brand-muted tracking-widest uppercase px-1">ÖZGEÇMİŞTEN ÇIKARILAN YETENEKLER</h4>
              <div class="flex flex-wrap gap-2 pt-xs">
                ${skillsHtml}
              </div>
            </div>

            <!-- Chunks Container -->
            <div class="space-y-sm flex-1 flex flex-col overflow-hidden">
              <h4 class="text-[10px] font-bold text-brand-muted tracking-widest uppercase px-1">BÖLÜMLERE GÖRE PARÇALAMA (CHUNKS)</h4>
              <div class="space-y-4 overflow-y-auto flex-1 pr-xs custom-scrollbar mt-xs" style="max-height: 280px;">
                ${chunkHtml}
              </div>
            </div>

            <!-- Floating Status Bar -->
            <div class="mt-auto p-4 rounded-2xl bg-white/5 border border-white/10 shadow-xl relative overflow-hidden shrink-0">
              <div class="absolute top-0 left-0 w-1 h-full bg-brand-accent"></div>
              <div class="flex gap-3 items-start">
                <div class="mt-0.5">
                  <i class="fa-solid fa-wand-magic-sparkles text-brand-accent text-sm"></i>
                </div>
                <p class="text-[10px] text-brand-text/80 leading-relaxed text-left">
                  <span class="font-bold text-brand-accent">Gün 13:</span> CV bölümlere ayrıldı. Yarın veriler <span class="italic font-bold text-brand-accent">Gemini AI</span> derin analizine aktarılacaktır.
                </p>
              </div>
            </div>
          </div>
        `;
      } else {
        // Standard full AI report (for Day 14)
        const strengthsHtml = Array.isArray(analysis.strengths) && analysis.strengths.length > 0
          ? analysis.strengths.map(st => `<li>${st}</li>`).join('')
          : '<li>Analiz başarısız veya veri yok.</li>';

        const weaknessesHtml = Array.isArray(analysis.weaknesses) && analysis.weaknesses.length > 0
          ? analysis.weaknesses.map(w => `<li>${w}</li>`).join('')
          : '<li>Analiz başarısız veya veri yok.</li>';

        const skillsHtml = Array.isArray(analysis.skills) && analysis.skills.length > 0
          ? analysis.skills.map(s => `
              <span class="px-3 py-1.5 rounded-full bg-brand-accent/10 border border-brand-accent/20 text-brand-accent text-xs font-semibold shadow-sm transform hover:scale-105 transition-transform cursor-default">
                ${s}
              </span>
            `).join('')
          : `<span class="text-xs text-brand-muted">Yetenek kelimeleri çıkarılamadı.</span>`;

        contentArea.innerHTML = `
          <div class="space-y-lg flex flex-col h-full overflow-y-auto pr-xs custom-scrollbar">
            <!-- Score Card -->
            <div class="flex items-center gap-lg bg-brand-card/50 p-5 rounded-2xl border border-brand-border shrink-0 text-left">
              <div class="relative w-20 h-20 flex items-center justify-center shrink-0">
                <svg class="w-full h-full transform -rotate-90" viewBox="0 0 36 36">
                  <path class="text-brand-border" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="currentColor" stroke-width="3"></path>
                  <path class="text-brand-success" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="currentColor" stroke-dasharray="${analysis.atsScore}, 100" stroke-linecap="round" stroke-width="3"></path>
                </svg>
                <span class="absolute text-headline-sm font-bold text-brand-text">%${analysis.atsScore}</span>
              </div>
              <div>
                <span class="text-label-sm text-brand-accent uppercase font-bold tracking-wider">GENEL UYUM SKORU</span>
                <h5 class="text-body-md font-bold text-brand-text mt-xs">${analysis.role || 'Özgeçmiş Analizi'}</h5>
                <p class="text-label-md text-brand-muted mt-0.5">Yapay zeka uyumluluk skoru hesaplandı.</p>
              </div>
            </div>

            <!-- Skills cloud -->
            <div class="space-y-sm shrink-0 text-left">
              <h4 class="text-[10px] font-bold text-brand-muted tracking-widest uppercase px-1">ÖNE ÇIKAN YETENEKLER</h4>
              <div class="flex flex-wrap gap-2 pt-xs">
                ${skillsHtml}
              </div>
            </div>

            <!-- Strengths and Weaknesses -->
            <div class="grid grid-cols-1 gap-md pt-xs shrink-0">
              <div class="bg-brand-success/5 border border-brand-success/15 p-5 rounded-2xl space-y-2 text-left">
                <span class="text-label-sm text-brand-success font-bold flex items-center gap-xs">
                  <i class="fa-regular fa-thumbs-up text-sm mr-1"></i> GÜÇLÜ YÖNLER
                </span>
                <ul class="text-xs text-brand-muted space-y-1.5 list-disc pl-md">
                  ${strengthsHtml}
                </ul>
              </div>
              
              <div class="bg-brand-danger/5 border border-brand-danger/15 p-5 rounded-2xl space-y-2 text-left">
                <span class="text-label-sm text-brand-danger font-bold flex items-center gap-xs">
                  <i class="fa-solid fa-triangle-exclamation text-sm mr-1"></i> GELİŞİM ALANLARI
                </span>
                <ul class="text-xs text-brand-muted space-y-1.5 list-disc pl-md">
                  ${weaknessesHtml}
                </ul>
              </div>
            </div>
          </div>
        `;
      }
    } else if (status === 'PROCESSING') {
      statusIndicator.innerHTML = `<i class="fa-solid fa-circle-notch text-brand-accent text-3xl animate-spin"></i>`;
      contentArea.innerHTML = `
        <div class="text-center py-xl text-brand-muted flex flex-col items-center justify-center h-full space-y-md my-auto">
          <i class="fa-solid fa-circle-notch text-[64px] text-brand-accent animate-spin mb-4"></i>
          <h4 class="text-headline-sm font-bold text-brand-text">Metin Çıkarılıyor...</h4>
          <p class="text-body-sm text-center max-w-[280px]">Özgeçmiş PDF belgesinden metinler ayıklanıyor ve semantik arama chunk'larına bölünüyor.</p>
        </div>
      `;
    } else if (status === 'PENDING') {
      statusIndicator.innerHTML = `<i class="fa-regular fa-clock text-brand-muted text-3xl animate-pulse"></i>`;
      contentArea.innerHTML = `
        <div class="text-center py-xl text-brand-muted flex flex-col items-center justify-center h-full space-y-md my-auto">
          <i class="fa-regular fa-clock text-[64px] text-brand-muted animate-pulse mb-4"></i>
          <h4 class="text-headline-sm font-bold text-brand-text">İşlem Sırasında</h4>
          <p class="text-body-sm text-center max-w-[280px]">CV dosyası sunucuya ulaştı, metin çıkarma sırasının kendisine gelmesi bekleniyor.</p>
        </div>
      `;
    } else {
      statusIndicator.innerHTML = `<i class="fa-solid fa-circle-exclamation text-brand-danger text-3xl"></i>`;
      contentArea.innerHTML = `
        <div class="text-center py-xl text-brand-danger flex flex-col items-center justify-center h-full space-y-md my-auto">
          <i class="fa-solid fa-circle-exclamation text-[64px] mb-4"></i>
          <h4 class="text-headline-sm font-bold text-brand-text">Ayrıştırma Hatası</h4>
          <p class="text-body-sm text-center max-w-[280px]">PDF belgesi parse edilirken sunucu hatası oluştu. Lütfen dosyanın şifreli veya bozuk olmadığından emin olun.</p>
        </div>
      `;
    }
  }

  // Set up dropzone and upload behaviors
  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('cv-file-input');
  const progressContainer = document.getElementById('upload-progress-container');
  const progressBar = document.getElementById('upload-progress-bar');
  const percentText = document.getElementById('upload-percent');
  const statusText = document.getElementById('upload-status-text');

  dropZone?.addEventListener('click', () => fileInput?.click());
  dropZone?.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('border-brand-accent', 'bg-brand-accent/5'); });
  dropZone?.addEventListener('dragleave', () => { dropZone.classList.remove('border-brand-accent', 'bg-brand-accent/5'); });
  dropZone?.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-brand-accent', 'bg-brand-accent/5');
    const files = e.dataTransfer?.files;
    if (files && files.length > 0) handleCVUpload(files[0]);
  });

  fileInput?.addEventListener('change', () => {
    if (fileInput.files && fileInput.files.length > 0) handleCVUpload(fileInput.files[0]);
  });

  async function handleCVUpload(file) {
    if (file.type !== 'application/pdf') {
      alert('Lütfen sadece PDF dosyası yükleyin.');
      return;
    }
    
    if (file.size > 5 * 1024 * 1024) {
      alert('Maksimum dosya boyutu limitini (5MB) aştınız.');
      return;
    }
    
    if (progressContainer && progressBar && percentText && statusText) {
      progressContainer.classList.remove('hidden');
      progressBar.style.width = '0%';
      percentText.textContent = '0%';
      progressBar.style.backgroundColor = 'var(--md-sys-color-primary)';
      statusText.textContent = 'Dosya sunucuya gönderiliyor...';
      
      const formData = new FormData();
      formData.append('cv', file);
      
      try {
        const res = await fetch('/api/cv/upload', {
          method: 'POST',
          body: formData
        });
        
        if (!res.ok) {
          const errData = await res.json();
          throw new Error(errData.message || 'Yükleme başarısız.');
        }
        
        const data = await res.json();
        progressBar.style.width = '100%';
        percentText.textContent = '100%';
        statusText.textContent = 'CV başarıyla yüklendi, analiz sıraya alındı!';
        
        // Refresh list
        selectedCvId = data.cv.id;
        await loadCVList();
        
      } catch (err) {
        console.error(err);
        statusText.textContent = `Hata: ${err.message}`;
        progressBar.style.width = '100%';
        progressBar.style.backgroundColor = 'rgba(255, 0, 0, 0.6)';
      }
    }
  }

  // Load the initial list on mount
  loadCVList();
</script>
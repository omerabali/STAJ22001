---
import UserLayout from '../layouts/UserLayout.astro';
---

<UserLayout title="Beacon AI - Analiz Sonuçlarım" headerTitle="Analiz Sonuçlarım">
  <div class="flex gap-6 h-full min-h-[600px] flex-col lg:flex-row">

    <!-- ═══════════════════════════════════════
         LEFT PANEL: Tüm CV Listesi
    ════════════════════════════════════════ -->
    <div class="flex flex-col flex-1 min-w-0">
      <div class="glass-card rounded-2xl flex flex-col overflow-hidden h-full shadow-[0_8px_32px_rgba(0,0,0,0.4)]">
        <!-- Panel Header -->
        <div class="p-6 border-b border-brand-border/60 relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-r from-brand-accent/5 to-transparent pointer-events-none"></div>
          <h3 class="text-lg font-bold text-brand-text relative z-10">Tüm Yüklenen CV'ler</h3>
          <p class="text-sm text-brand-muted mt-1 relative z-10">Tüm özgeçmişlerinizi ve analiz durumlarını buradan yönetebilirsiniz.</p>
        </div>

        <!-- Table -->
        <div class="flex-1 overflow-auto custom-scrollbar p-2">
          <table class="w-full text-left text-sm text-brand-text border-separate border-spacing-y-1">
            <thead class="text-xs text-brand-muted uppercase sticky top-0 z-10 backdrop-blur-md">
              <tr>
                <th class="px-5 py-3 font-semibold rounded-tl-lg" scope="col">Belge Adı</th>
                <th class="px-5 py-3 font-semibold text-center" scope="col">Yükleme Tarihi</th>
                <th class="px-5 py-3 font-semibold text-center" scope="col">Analiz Durumu</th>
                <th class="px-5 py-3 font-semibold text-center" scope="col">Uyum Skoru</th>
                <th class="px-5 py-3 font-semibold text-right rounded-tr-lg" scope="col">İşlem</th>
              </tr>
            </thead>
            <tbody id="my-cvs-body">
              <tr>
                <td colspan="5" class="px-6 py-8 text-center text-brand-muted">Yüklemeler sorgulanıyor...</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════════════════
         RIGHT PANEL: Detay / Boş Durum
    ════════════════════════════════════════ -->
    <div class="w-full lg:w-[480px] xl:w-[540px] flex-shrink-0">
      <div class="glass-card rounded-2xl h-full flex flex-col shadow-[0_8px_32px_rgba(0,0,0,0.5)] relative overflow-hidden" id="analysis-detail-card">

        <!-- Background accent glow -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-brand-accent/5 rounded-full blur-3xl pointer-events-none"></div>

        <!-- ─── EMPTY STATE ─── -->
        <div class="flex flex-col items-center justify-center h-full p-8 relative z-10" id="no-analysis-state">
          <!-- Atmospheric dot grid -->
          <div class="absolute inset-0 pointer-events-none opacity-40"
            style="background-image: radial-gradient(circle at center, rgba(56,189,248,0.04) 1px, transparent 1px); background-size: 22px 22px;">
          </div>

          <!-- Animated icon cluster -->
          <div class="w-44 h-44 mb-6 relative flex items-center justify-center animate-float">
            <div class="absolute w-36 h-36 bg-brand-accent/8 rounded-full blur-2xl mix-blend-screen animate-pulse-slow"></div>
            <div class="absolute w-40 h-40 border border-brand-accent/8 rounded-full animate-spin-slow"></div>
            <div class="w-32 h-32 rounded-full border border-brand-accent/20 bg-brand-card/40 flex items-center justify-center relative shadow-[inset_0_0_24px_rgba(56,189,248,0.08)]">
              <div class="absolute inset-0 rounded-full border border-brand-accent/15 animate-ping opacity-30"></div>
              <!-- Chart-pie icon like Stitch design -->
              <i class="fa-solid fa-chart-pie text-brand-accent text-5xl drop-shadow-[0_0_18px_rgba(56,189,248,0.6)]"></i>
            </div>
          </div>

          <div class="text-center relative z-10 max-w-xs">
            <h3 class="text-xl font-bold text-brand-text mb-2">Detaylı Analiz Paneli</h3>
            <p class="text-sm text-brand-muted leading-relaxed">
              Yandaki listeden bir özgeçmiş seçerek yapay zeka analiz raporunu detaylıca görüntüleyebilirsiniz.
            </p>
          </div>

          <!-- Bottom hint bar -->
          <div class="mt-8 w-full border-t border-brand-border/40 pt-4 flex items-center justify-center gap-2 text-xs text-brand-muted/60 relative z-10">
            <i class="fa-solid fa-microchip text-brand-accent/50 animate-pulse"></i>
            <span>Beacon AI sistemi analiz için hazır bekliyor.</span>
          </div>
        </div>

        <!-- ─── ACTIVE ANALYSIS STATE ─── -->
        <div class="hidden flex-col h-full relative z-10" id="active-analysis-state">

          <!-- Panel Header -->
          <div class="p-6 border-b border-brand-border/60 flex items-start justify-between">
            <div class="min-w-0 flex-1">
              <h3 class="text-lg font-extrabold text-brand-text truncate tracking-tight max-w-[280px]" id="analysis-cv-name">Özgeçmiş</h3>
              <p class="text-xs text-brand-accent/80 font-medium mt-0.5">Yapay Zeka Analiz Raporu</p>
            </div>
            <div id="analysis-status-indicator" class="shrink-0 ml-3">
              <span class="material-symbols-outlined text-brand-success text-3xl">verified</span>
            </div>
          </div>

          <!-- Scrollable Content -->
          <div class="flex-1 overflow-y-auto custom-scrollbar p-6 flex flex-col gap-6" id="analysis-content-area">
            <!-- Dynamic content injected here -->
          </div>

          </div>

      </div>
    </div>

  </div>

  <script is:inline>
    let selectedCvId = null;
    let activeInterval = null;

    // Delete CV handler
    window.deleteCV = async function(cvId) {
      if (!confirm('Bu özgeçmişi ve tüm ilişkili verileri silmek istediğinize emin misiniz?')) return;
      try {
        const res = await fetch(`/api/cv/${cvId}`, { method: 'DELETE' });
        if (!res.ok) {
          const err = await res.json();
          throw new Error(err.message || 'Silme işlemi başarısız.');
        }
        if (selectedCvId === cvId) {
          selectedCvId = null;
          document.getElementById('no-analysis-state').classList.remove('hidden');
          document.getElementById('active-analysis-state').classList.remove('flex');
          document.getElementById('active-analysis-state').classList.add('hidden');
        }
        await loadCVList();
      } catch (err) {
        console.error(err);
        alert(err.message);
      }
    };

    async function loadCVList() {
      try {
        const res = await fetch('/api/cv/list');
        if (!res.ok) return;
        const data = await res.json();
        const tbody = document.getElementById('my-cvs-body');
        if (!tbody) return;

        if (!data.cvs || data.cvs.length === 0) {
          tbody.innerHTML = `
            <tr>
              <td colspan="5" class="px-6 py-10 text-center text-brand-muted">Henüz yüklenmiş bir CV bulunamadı.</td>
            </tr>
          `;
          return;
        }

        tbody.innerHTML = '';
        let hasPendingOrProcessing = false;

        data.cvs.forEach(cv => {
          const latestAnalysis = cv.analyses && cv.analyses[0];
          const status = latestAnalysis ? latestAnalysis.status : 'PENDING';
          if (status === 'PENDING' || status === 'PROCESSING') hasPendingOrProcessing = true;
          const dateStr = new Date(cv.createdAt).toLocaleDateString('tr-TR');

          // Status badge
          let statusBadge = '';
          if (status === 'PENDING') {
            statusBadge = `<span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-yellow-500/10 text-yellow-400 border border-yellow-500/20"><span class="w-1.5 h-1.5 rounded-full bg-yellow-400 animate-pulse"></span>Sırada</span>`;
          } else if (status === 'PROCESSING') {
            statusBadge = `<span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-brand-accent/10 text-brand-accent border border-brand-accent/20"><span class="w-1.5 h-1.5 rounded-full bg-brand-accent animate-spin"></span>İşleniyor...</span>`;
          } else if (status === 'COMPLETED') {
            statusBadge = `<span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 shadow-[0_0_10px_rgba(52,211,153,0.1)]"><span class="w-1.5 h-1.5 rounded-full bg-emerald-400 shadow-[0_0_5px_rgba(52,211,153,0.8)]"></span>Hazır</span>`;
          } else {
            statusBadge = `<span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-red-500/10 text-red-400 border border-red-500/20 shadow-[0_0_10px_rgba(239,68,68,0.1)]"><span class="w-1.5 h-1.5 rounded-full bg-red-400"></span>Hata</span>`;
          }

          // Score column
          let scoreCell = '';
          if (latestAnalysis && latestAnalysis.atsScore !== null) {
            const pct = latestAnalysis.atsScore;
            scoreCell = `
              <div class="relative inline-flex items-center justify-center w-12 h-12">
                <svg class="w-full h-full transform -rotate-90" viewBox="0 0 36 36">
                  <path class="text-brand-border" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="currentColor" stroke-width="3"></path>
                  <path class="text-brand-accent drop-shadow-[0_0_4px_rgba(56,189,248,0.8)]" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="currentColor" stroke-dasharray="${pct}, 100" stroke-width="3"></path>
                </svg>
                <div class="absolute flex flex-col items-center justify-center text-brand-accent font-mono text-xs font-bold">
                  ${pct}<span class="text-[8px] -mt-1 opacity-70">%</span>
                </div>
              </div>`;
          } else {
            scoreCell = `<span class="text-brand-muted font-mono text-sm">—</span>`;
          }

          const isSelected = selectedCvId === cv.id;
          const tr = document.createElement('tr');
          tr.className = `group rounded-xl cursor-pointer transition-all duration-200 ${
            isSelected
              ? 'bg-brand-accent/10 shadow-[inset_0_0_0_1px_rgba(56,189,248,0.3)]'
              : 'hover:bg-white/[0.03]'
          }`;

          tr.onclick = () => {
            selectedCvId = cv.id;
            // Update row highlights
            document.querySelectorAll('#my-cvs-body tr').forEach(r => {
              r.classList.remove('bg-brand-accent/10', 'shadow-[inset_0_0_0_1px_rgba(56,189,248,0.3)]');
              r.classList.add('hover:bg-white/[0.03]');
            });
            tr.classList.add('bg-brand-accent/10', 'shadow-[inset_0_0_0_1px_rgba(56,189,248,0.3)]');
            tr.classList.remove('hover:bg-white/[0.03]');
            showAnalysisDetails(cv, latestAnalysis);
          };

          tr.innerHTML = `
            <td class="px-5 py-4 rounded-l-xl">
              <div class="flex items-center gap-3 overflow-hidden">
                <div class="w-8 h-8 rounded-lg bg-brand-accent/10 flex items-center justify-center border border-brand-accent/20 group-hover:border-brand-accent/40 transition-colors shrink-0">
                  <i class="fa-regular fa-file-lines text-brand-accent"></i>
                </div>
                <span class="font-semibold text-brand-text truncate max-w-[180px] group-hover:text-white transition-colors">${cv.fileName}</span>
              </div>
            </td>
            <td class="px-5 py-4 text-center text-brand-muted font-mono text-xs">${dateStr}</td>
            <td class="px-5 py-4 text-center">${statusBadge}</td>
            <td class="px-5 py-4 text-center">${scoreCell}</td>
            <td class="px-5 py-4 text-right rounded-r-xl" onclick="event.stopPropagation();">
              <button
                class="text-brand-muted hover:text-red-400 hover:bg-red-500/10 p-2 rounded-lg transition-all duration-300"
                onclick="deleteCV('${cv.id}')"
                title="Sil">
                <i class="fa-regular fa-trash-can"></i>
              </button>
            </td>
          `;
          tbody.appendChild(tr);

          if (selectedCvId === cv.id) showAnalysisDetails(cv, latestAnalysis);
        });

        if (hasPendingOrProcessing) {
          if (!activeInterval) activeInterval = setInterval(loadCVList, 3000);
        } else {
          if (activeInterval) { clearInterval(activeInterval); activeInterval = null; }
        }
      } catch (err) {
        console.error('CV yükleme geçmişi alınamadı:', err);
      }
    }

    function showAnalysisDetails(cv, analysis) {
      const noState = document.getElementById('no-analysis-state');
      const activeState = document.getElementById('active-analysis-state');
      if (!noState || !activeState) return;

      noState.classList.add('hidden');
      activeState.classList.remove('hidden');
      activeState.classList.add('flex');

      document.getElementById('analysis-cv-name').textContent = cv.fileName;

      const statusIndicator = document.getElementById('analysis-status-indicator');
      const contentArea = document.getElementById('analysis-content-area');

      if (!analysis) return;
      const status = analysis.status;

      if (status === 'COMPLETED') {
        statusIndicator.innerHTML = `<span class="material-symbols-outlined text-emerald-400 text-3xl drop-shadow-[0_0_8px_rgba(52,211,153,0.7)]">verified</span>`;

        if (analysis.atsScore === null) {
          // Day 13: chunks + skills, no score yet
          const skillsHtml = Array.isArray(analysis.skills) && analysis.skills.length > 0
            ? analysis.skills.map(s => `
                <span class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-brand-accent/10 text-brand-accent border border-brand-accent/20 shadow-[0_2px_10px_rgba(56,189,248,0.1)] hover:bg-brand-accent/20 hover:border-brand-accent/40 transition-all cursor-default">${s}</span>
              `).join('')
            : `<span class="text-xs text-brand-muted">Yetenek kelimeleri çıkarılamadı.</span>`;

          const chunkHtml = cv.chunks && cv.chunks.length > 0
            ? cv.chunks.map((chunk, idx) => {
                const firstLB = chunk.content.indexOf('\n');
                const header = firstLB !== -1 ? chunk.content.substring(0, firstLB) : `PARÇA #${idx + 1}`;
                const body = firstLB !== -1 ? chunk.content.substring(firstLB + 1) : chunk.content;
                const wordCount = body.split(/\s+/).filter(w => w.length > 0).length;
                const isFirst = idx === 0;
                return `
                  <div class="${isFirst
                    ? 'bg-brand-bg/60 border border-brand-accent/40 rounded-xl overflow-hidden shadow-[0_0_20px_rgba(56,189,248,0.15),inset_0_2px_10px_rgba(0,0,0,0.5)] relative'
                    : 'bg-brand-bg/30 border border-brand-border/30 rounded-xl overflow-hidden hover:border-brand-border/60 transition-colors duration-300'
                  }">
                    ${isFirst ? '<div class="absolute left-0 top-0 bottom-0 w-1 bg-brand-accent shadow-[0_0_10px_rgba(56,189,248,0.8)]"></div>' : ''}
                    <div class="px-4 py-2 border-b border-brand-border/30 flex justify-between items-center ${isFirst ? 'pl-5' : ''}">
                      <span class="text-xs font-bold ${isFirst ? 'text-brand-accent' : 'text-brand-muted'} tracking-wide">${header}</span>
                      <span class="text-[10px] font-semibold ${isFirst ? 'text-brand-accent/70 bg-brand-accent/10' : 'text-brand-muted/60 bg-white/5'} px-2 py-0.5 rounded-md">${wordCount} kelime</span>
                    </div>
                    <div class="p-4 text-xs text-brand-muted font-mono whitespace-pre-wrap leading-relaxed max-h-28 overflow-hidden relative ${isFirst ? 'pl-5' : ''}">
                      ${body}
                      <div class="absolute bottom-0 left-0 right-0 h-8 bg-gradient-to-t from-brand-card/90 to-transparent pointer-events-none"></div>
                    </div>
                  </div>
                `;
              }).join('')
            : `<p class="text-xs text-brand-muted text-center py-6">Metin parçaları veritabanında bulunamadı.</p>`;

          contentArea.innerHTML = `
            <div class="space-y-3">
              <h4 class="text-[10px] font-extrabold text-brand-muted uppercase tracking-widest flex items-center gap-2">
                <i class="fa-solid fa-layer-group text-brand-accent"></i> Özgeçmişten Çıkarılan Yetenekler
              </h4>
              <div class="flex flex-wrap gap-2 p-4 bg-brand-bg/30 rounded-xl border border-brand-border/20 shadow-inner">
                ${skillsHtml}
              </div>
            </div>
            <div class="flex flex-col gap-3 flex-1">
              <h4 class="text-[10px] font-extrabold text-brand-muted uppercase tracking-widest flex items-center gap-2">
                <i class="fa-solid fa-puzzle-piece text-brand-accent"></i> Bölümlere Göre Parçalama (Chunks)
              </h4>
              <div class="space-y-3 overflow-y-auto custom-scrollbar flex-1 pr-1" style="max-height: 340px;">
                ${chunkHtml}
              </div>
            </div>
          `;



        } else {
          // Full AI report (Day 14+)
          const pct = analysis.atsScore;
          const skillsHtml = Array.isArray(analysis.skills) && analysis.skills.length > 0
            ? analysis.skills.map(s => `<span class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-brand-accent/10 text-brand-accent border border-brand-accent/20 hover:bg-brand-accent/20 transition-all cursor-default">${s}</span>`).join('')
            : `<span class="text-xs text-brand-muted">Yetenek kelimeleri çıkarılamadı.</span>`;
          const strengthsHtml = Array.isArray(analysis.strengths) && analysis.strengths.length > 0
            ? analysis.strengths.map(st => `<li>${st}</li>`).join('') : '<li>Veri yok.</li>';
          const weaknessesHtml = Array.isArray(analysis.weaknesses) && analysis.weaknesses.length > 0
            ? analysis.weaknesses.map(w => `<li>${w}</li>`).join('') : '<li>Veri yok.</li>';

          contentArea.innerHTML = `
            <!-- Score Ring -->
            <div class="flex items-center gap-5 bg-brand-bg/40 p-5 rounded-2xl border border-brand-border/40 shrink-0">
              <div class="relative w-20 h-20 flex items-center justify-center shrink-0">
                <svg class="w-full h-full transform -rotate-90" viewBox="0 0 36 36">
                  <path class="text-brand-border" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="currentColor" stroke-width="3"></path>
                  <path class="text-brand-accent" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="currentColor" stroke-dasharray="${pct}, 100" stroke-linecap="round" stroke-width="3"></path>
                </svg>
                <span class="absolute text-lg font-bold text-brand-text">%${pct}</span>
              </div>
              <div>
                <span class="text-[10px] text-brand-accent font-bold tracking-widest uppercase">Genel Uyum Skoru</span>
                <h5 class="text-base font-bold text-brand-text mt-1">${analysis.role || 'Özgeçmiş Analizi'}</h5>
                <p class="text-xs text-brand-muted mt-0.5">Yapay zeka uyumluluk skoru hesaplandı.</p>
              </div>
            </div>
            <!-- Skills -->
            <div class="space-y-2">
              <h4 class="text-[10px] font-bold text-brand-muted tracking-widest uppercase flex items-center gap-2">
                <i class="fa-solid fa-layer-group text-brand-accent"></i> Öne Çıkan Yetenekler
              </h4>
              <div class="flex flex-wrap gap-2 pt-1">${skillsHtml}</div>
            </div>
            <!-- Strengths / Weaknesses -->
            <div class="space-y-3">
              <div class="bg-emerald-500/5 border border-emerald-500/15 p-4 rounded-2xl space-y-2">
                <span class="text-xs text-emerald-400 font-bold flex items-center gap-1.5"><i class="fa-regular fa-thumbs-up"></i> Güçlü Yönler</span>
                <ul class="text-xs text-brand-muted space-y-1 list-disc pl-4">${strengthsHtml}</ul>
              </div>
              <div class="bg-red-500/5 border border-red-500/15 p-4 rounded-2xl space-y-2">
                <span class="text-xs text-red-400 font-bold flex items-center gap-1.5"><i class="fa-solid fa-triangle-exclamation"></i> Gelişim Alanları</span>
                <ul class="text-xs text-brand-muted space-y-1 list-disc pl-4">${weaknessesHtml}</ul>
              </div>
            </div>
          `;
          footerBar.classList.add('hidden');
        }

      } else if (status === 'PENDING') {
        statusIndicator.innerHTML = `<i class="fa-regular fa-clock text-brand-muted text-3xl animate-pulse"></i>`;
        contentArea.innerHTML = `
          <div class="flex flex-col items-center justify-center flex-1 text-center py-10 space-y-4">
            <i class="fa-regular fa-clock text-5xl text-brand-muted animate-pulse mb-2"></i>
            <h4 class="text-base font-bold text-brand-text">İşlem Sırasında</h4>
            <p class="text-sm text-brand-muted max-w-[240px]">CV dosyası sunucuya ulaştı, metin çıkarma sırasının kendisine gelmesi bekleniyor.</p>
          </div>`;

      } else if (status === 'PROCESSING') {
        statusIndicator.innerHTML = `<i class="fa-solid fa-circle-notch text-brand-accent text-3xl animate-spin"></i>`;
        contentArea.innerHTML = `
          <div class="flex flex-col items-center justify-center flex-1 text-center py-10 space-y-4">
            <i class="fa-solid fa-circle-notch text-5xl text-brand-accent animate-spin mb-2"></i>
            <h4 class="text-base font-bold text-brand-text">Metin Çıkarılıyor...</h4>
            <p class="text-sm text-brand-muted max-w-[240px]">Özgeçmiş PDF belgesinden metinler ayıklanıyor ve semantik arama chunk'larına bölünüyor.</p>
          </div>`;

      } else {
        statusIndicator.innerHTML = `<i class="fa-solid fa-circle-exclamation text-red-400 text-3xl"></i>`;
        contentArea.innerHTML = `
          <div class="flex flex-col items-center justify-center flex-1 text-center py-10 space-y-4">
            <i class="fa-solid fa-circle-exclamation text-5xl text-red-400 mb-2"></i>
            <h4 class="text-base font-bold text-brand-text">Ayrıştırma Hatası</h4>
            <p class="text-sm text-brand-muted max-w-[240px]">PDF belgesi parse edilirken sunucu hatası oluştu. Dosyanın şifreli veya bozuk olmadığından emin olun.</p>
          </div>`;
      }
    }

    loadCVList();
  </script>
</UserLayout>

<footer class="w-full border-t border-white/10" style="background-color: #1a1918;">
  <div class="max-w-max-width mx-auto px-margin-mobile md:px-margin-desktop py-xl">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-12 mb-16 max-w-4xl mx-auto">
        <div class="flex flex-col gap-4">
            <h4 class="font-bold text-white text-xs uppercase tracking-wider mb-2">Ürün</h4>
            <a class="text-sm hover:text-white transition-colors duration-200" style="color: rgba(255,255,255,0.6);" href="/login">Özellikler</a>
            <a class="text-sm hover:text-white transition-colors duration-200" style="color: rgba(255,255,255,0.6);" href="/login">Nasıl Çalışır</a>
            <a class="text-sm hover:text-white transition-colors duration-200" style="color: rgba(255,255,255,0.6);" href="/login">SSS</a>
            <a class="text-sm hover:text-white transition-colors duration-200" style="color: rgba(255,255,255,0.6);" href="/login">Fiyatlandırma</a>
        </div>
        <div class="flex flex-col gap-4">
            <h4 class="font-bold text-white text-xs uppercase tracking-wider mb-2">Kaynaklar</h4>
            <a class="text-sm hover:text-white transition-colors duration-200" style="color: rgba(255,255,255,0.6);" href="/login">Blog</a>

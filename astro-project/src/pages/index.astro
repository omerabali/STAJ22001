---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Beacon • CV'nin Gerçek Potansiyelini Keşfet" bodyClass="theme-landing font-body-md text-body-md bg-background text-on-surface">
	<!-- Navigation -->
	<nav class="fixed top-0 w-full z-50 border-b border-outline-variant glass">
		<div class="flex justify-between items-center h-16 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto w-full">
			<div class="font-headline-md text-headline-md font-bold text-on-surface flex items-center gap-2">
				<img src="/mixboard.png" alt="Beacon Logo" class="h-8 w-auto object-contain" />
				Beacon <span class="text-[#7c5cfc]">•</span>
			</div>
			<div class="hidden md:flex items-center gap-8">
				<a class="text-on-surface-variant font-label-md hover:text-primary transition-colors" href="#">Özellikler</a>
				<a class="text-on-surface-variant font-label-md hover:text-primary transition-colors" href="#">Nasıl Çalışır</a>
				<a class="text-on-surface-variant font-label-md hover:text-primary transition-colors" href="#">SSS</a>
			</div>
			<div class="flex items-center gap-4">
				<a class="text-on-surface-variant font-label-md hover:text-primary transition-colors" href="/login">Giriş Yap</a>
				<a class="bg-[#7c5cfc] text-white px-6 py-2 rounded-lg font-label-md hover:bg-opacity-90 transition-all active:scale-95" href="/login">Başla</a>
			</div>
		</div>
	</nav>
	
	<main class="relative pt-32">
		<!-- Hero Section -->
		<section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop grid md:grid-cols-2 gap-16 items-center mb-32">
			<div class="space-y-8">
				<div class="inline-block px-4 py-1 rounded-full border border-[#7c5cfc]/30 bg-[#7c5cfc]/10 text-[#7c5cfc] font-label-sm tracking-wider uppercase">
					AI DESTEKLİ CV ANALİZİ
				</div>
				<h1 class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg leading-tight text-on-surface font-bold">
					CV'nin gerçek <span class="text-[#7c5cfc]">potansiyelini</span> keşfet.
				</h1>
				<p class="text-on-surface-variant text-body-lg max-w-lg">
					CV'ni yükle, yapay zeka güçlü yönlerini, zayıf yönlerini ve gelişim önerilerini saniyeler içinde analiz etsin.
				</p>
				<div class="flex flex-col sm:flex-row items-start sm:items-center gap-6">
					<a class="bg-[#7c5cfc] text-white px-8 py-4 rounded-xl font-label-md text-lg hover:shadow-[0_0_20px_rgba(124,92,252,0.4)] transition-all active:scale-95 flex items-center gap-2" href="/login">
						Ücretsiz Analiz Et
						<span class="material-symbols-outlined">arrow_forward</span>
					</a>
				</div>
				<div class="flex flex-wrap gap-4">
					<span class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-surface border border-outline-variant text-on-surface-variant text-sm">
						✓ Ücretsiz
					</span>
					<span class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-surface border border-outline-variant text-on-surface-variant text-sm">
						⚡ Saniyeler içinde
					</span>
					<span class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-surface border border-outline-variant text-on-surface-variant text-sm">
						🔒 Güvenli
					</span>
				</div>
			</div>
			<div class="relative group">
				<div class="absolute -inset-1 bg-gradient-to-r from-[#7c5cfc] to-primary rounded-2xl blur opacity-25 group-hover:opacity-40 transition duration-1000"></div>
				<div class="relative bg-surface border border-outline-variant rounded-2xl overflow-hidden purple-glow shadow-2xl">
					<img alt="Beacon CV Analysis Dashboard" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAWVya-BHTtzPF3Zwi5kZSYEoT_IssSAKeapkd2-ZKQhFplq-m9PLl6W4NkzhQwn5yXQzSK5yIfnQvkBIi17Lq_TWlQ4kdGZGjtDHzqSxai-vmuSOKTDAHNdHhU8kMoNo4KngGZu8hWqX3uPbkCI1mbELyP1Hv2Own5MAohqWv07bKLZiBQBssre3p3E-zmaR5G6ktBSlVisUO9M4zL8GsEwNRLcilGIW-6GnQgQoQnlX_q1SzGXWL2qoe1QuFxiJa6GIVm44cgHed5"/>
				</div>
			</div>
		</section>

		<!-- Problem Section -->
		<section class="py-24 bg-surface-container-lowest/50">
			<div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
				<h2 class="font-headline-lg text-headline-lg text-center mb-16 text-on-surface font-bold">CV'n yeterince iyi mi?</h2>
				<div class="grid md:grid-cols-3 gap-8">
					<div class="p-8 rounded-xl border border-outline-variant bg-surface card-hover group">
						<div class="text-[#7c5cfc] font-bold text-4xl mb-6 opacity-40 group-hover:opacity-100 transition-opacity">01</div>
						<h3 class="font-headline-md text-headline-md text-on-surface font-semibold mb-4">Görünürlük Sorunu</h3>
						<p class="text-on-surface-variant">ATS sistemleri CV'ni doğru okuyamıyor olabilir. Yapay zeka ile uyumluluğunu test et.</p>
					</div>
					<div class="p-8 rounded-xl border border-outline-variant bg-surface card-hover group">
						<div class="text-[#7c5cfc] font-bold text-4xl mb-6 opacity-40 group-hover:opacity-100 transition-opacity">02</div>
						<h3 class="font-headline-md text-headline-md text-on-surface font-semibold mb-4">İşe Alım Beklentileri</h3>
						<p class="text-on-surface-variant">İş verenlerin ne aradığını bilmiyorsun. Beacon ile modern standartlara uygun bir CV hazırla.</p>
					</div>
					<div class="p-8 rounded-xl border border-outline-variant bg-surface card-hover group">
						<div class="text-[#7c5cfc] font-bold text-4xl mb-6 opacity-40 group-hover:opacity-100 transition-opacity">03</div>
						<h3 class="font-headline-md text-headline-md text-on-surface font-semibold mb-4">Geri Bildirim Eksikliği</h3>
						<p class="text-on-surface-variant">Reddedilen başvuruların nedenini asla öğrenemiyorsun. Biz sana tam olarak neyi geliştirmen gerektiğini söylüyoruz.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Team Photo Section Break -->
		<section class="relative h-[600px] w-full overflow-hidden">
			<img alt="Beacon Ekibi" class="w-full h-full object-cover opacity-60" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBFzjwMg3vwbzuKGc7ZMhu-vz6_C8puKQBgECBCRWhQLI8Kv28IOv-IZMGsvVaNCUi2RAiasSLdnb-oe_wMLDSkHNP5AYAPkhiU6aqLAp844qzQ3dYZ14qtndvDGXQvIYq3IPhhhmkmNdmz3NHo7FR8h_FTeVab8vs1u46Th3wiG8jal1XjEFdBsCjSaaEVdcJw0OXHoNjDko0loQLD6II9XXa-Ai9mBx4QRyf0Q1OPJ7vEj3CO0yOy7hbJDpH9GhzRk0cJ3ZT2As42"/>
			<div class="absolute inset-0 bg-gradient-to-b from-background via-transparent to-background"></div>
			<div class="absolute inset-0 flex items-center justify-center text-center px-4">
				<div class="max-w-2xl">
					<h2 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface font-bold mb-6">İnsan Odaklı Teknoloji</h2>
					<p class="text-body-lg text-on-surface">Algoritmalarımızın arkasında, kariyer yolculuğunu kolaylaştırmak isteyen tutkulu bir ekip var.</p>
				</div>
			</div>
		</section>

		<!-- Solution Section -->
		<section class="py-32">
			<div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop space-y-32">
				<h2 class="font-headline-lg text-headline-lg text-center text-on-surface font-bold">Beacon CV'ni anlayan bir asistan.</h2>
				
				<!-- Solution 1: Analysis -->
				<div class="flex flex-col md:flex-row items-center gap-20">
					<div class="w-full md:w-1/2">
						<div class="p-1 bg-gradient-to-br from-[#7c5cfc]/50 to-transparent rounded-2xl shadow-2xl">
							<div class="bg-surface rounded-2xl aspect-[4/3] overflow-hidden relative border border-outline-variant">
								<img alt="Hands typing on keyboard" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBvkfhAZMk_gPyOGBp5hvmoMYxJxhNpu6KBFzAYLqAIFnz271m8wivRDdAPk2MdEKz7yHYU5NaEepsGNXd4dMYUOk0XyEOieLpdx0Gr4Msq-KuS-Z3M0sCzCBbLqjEj0Doz72--B4SDY14YR-UqGcSi72LtkKVmeRcGrnDSYLXC4dcswIXSzdufvU2FqN3A_7CFWnAG2hBDV_qwsCyqDmCqQmuWmj9s3n7hMRwh1W4RG8dwABAfA85PhKntlzIDTHqVzvCNdyAQJXS_"/>
							</div>
						</div>
					</div>
					<div class="w-full md:w-1/2 space-y-6">
						<h3 class="font-headline-lg-mobile md:font-headline-md text-primary font-semibold">Anında Analiz</h3>
						<p class="text-body-lg text-on-surface-variant">Sadece saniyeler içinde CV'ndeki tüm eksikleri, imla hatalarını ve yapısal bozuklukları tespit ediyoruz. Beklemek yok, karmaşa yok.</p>
					</div>
				</div>

				<!-- Solution 2: Strengths -->
				<div class="flex flex-col md:flex-row-reverse items-center gap-20">
					<div class="w-full md:w-1/2">
						<div class="p-1 bg-gradient-to-bl from-[#7c5cfc]/50 to-transparent rounded-2xl shadow-2xl">
							<div class="bg-surface rounded-2xl aspect-[4/3] overflow-hidden border border-outline-variant">
								<img alt="Tablet with skill radar chart" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB87jrVBc4yZS605Av8iNNluPTboUkH2o8K1RQkb3PgDRMr9MCAlTKCLCrfLxoTKNdNioEBzMfa7Q92fW04ZYyNz70hcKvnNcSP8Pqai2vbcM-qzY1QLb7neJf1k_IRVN6uFWeB5gKh9YQs69vaZpSd__segFOrG_4InG-0MjJHe6mMiSdxUf9KIOXwcixM2n6oMiC2se2feKw5S8arH4k1Vua8LCJuXYX3XdgO_PjAdTUNVQBBcQKPa5dFnzqXcgZOMjV58XXIi5wz"/>
							</div>
						</div>
					</div>
					<div class="w-full md:w-1/2 space-y-6 text-left">
						<h3 class="font-headline-lg-mobile md:font-headline-md text-primary font-semibold">Güçlü ve Zayıf Yönler</h3>
						<p class="text-body-lg text-on-surface-variant">Hangi yeteneklerinin parladığını, hangilerinin ise gölgede kaldığını görselleştiriyoruz. Kariyer hikayeni verilerle güçlendir.</p>
					</div>
				</div>

				<!-- Solution 3: Suggestions -->
				<div class="flex flex-col md:flex-row items-center gap-20">
					<div class="w-full md:w-1/2">
						<div class="p-1 bg-gradient-to-tr from-[#7c5cfc]/50 to-transparent rounded-2xl shadow-2xl">
							<div class="bg-surface rounded-2xl aspect-[4/3] overflow-hidden border border-outline-variant">
								<img alt="Professional young professional" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuD14_GKvriqH7zLnTnyBakcq-B8N4Syu6DT_CDxcWPN2BrB5S9IsN2X99xbwAS-l4dJ3lk6FYRnKVKJPbRnUZ8px7UeP29WOWd1JEczf1sEvfGesJ3OFJ102NS0vCNJg26nYr6UBTQSe8G4CNwk48nInDovMdtBNxxfSJEvRyIj-8CGQtlpEKcTcma6gwbAZhzPrunhMt7f7CSzAafutZE_Tc_YCC2mklJpVSTL0WfII7uC6ob4W6eiYXqbkWNlEGqk6hAbzcIV-ksd"/>
							</div>
						</div>
					</div>
					<div class="w-full md:w-1/2 space-y-6">
						<h3 class="font-headline-lg-mobile md:font-headline-md text-primary font-semibold">Kişisel Gelişim Önerileri</h3>
						<p class="text-body-lg text-on-surface-variant">Sadece eleştirmiyoruz. Eksik olan sertifikaları, kullanman gereken anahtar kelimeleri ve CV'ni nasıl bir üst seviyeye taşıyacağını adım adım gösteriyoruz.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- How It Works -->
		<section class="py-24 bg-surface-container-low">
			<div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
				<h2 class="font-headline-lg text-headline-lg text-center mb-16 text-on-surface font-bold">3 adımda CV analizin hazır.</h2>
				<div class="grid md:grid-cols-3 gap-12 relative">
					<div class="absolute top-12 left-0 w-full h-px bg-outline-variant hidden md:block z-0"></div>
					<div class="relative z-10 text-center space-y-6">
						<div class="w-16 h-16 bg-[#7c5cfc] text-white rounded-full flex items-center justify-center mx-auto text-xl font-bold border-4 border-background">1</div>
						<h3 class="font-headline-md text-headline-md font-semibold text-on-surface">Yükle</h3>
						<p class="text-on-surface-variant">PDF veya Word formatındaki CV'ni sisteme sürükle.</p>
					</div>
					<div class="relative z-10 text-center space-y-6">
						<div class="w-16 h-16 bg-[#7c5cfc] text-white rounded-full flex items-center justify-center mx-auto text-xl font-bold border-4 border-background">2</div>
						<h3 class="font-headline-md text-headline-md font-semibold text-on-surface">Analiz</h3>
						<p class="text-on-surface-variant">Yapay zekamız CV'ni saniyeler içinde tarasın.</p>
					</div>
					<div class="relative z-10 text-center space-y-6">
						<div class="w-16 h-16 bg-[#7c5cfc] text-white rounded-full flex items-center justify-center mx-auto text-xl font-bold border-4 border-background">3</div>
						<h3 class="font-headline-md text-headline-md font-semibold text-on-surface">Sonuçları Gör</h3>
						<p class="text-on-surface-variant">Kapsamlı raporuna ulaş ve hemen düzenlemeye başla.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="py-32 max-w-3xl mx-auto px-margin-mobile">
			<h2 class="font-headline-lg text-headline-lg text-center mb-16 text-on-surface font-bold">Sıkça Sorulan Sorular</h2>
			<div class="space-y-4">
				<details class="group bg-surface border border-outline-variant rounded-xl overflow-hidden">
					<summary class="flex justify-between items-center p-6 cursor-pointer hover:bg-surface-container transition-colors">
						<span class="font-headline-md text-lg text-on-surface font-semibold">Hizmet gerçekten ücretsiz mi?</span>
						<span class="material-symbols-outlined text-on-surface group-open:rotate-180 transition-transform">expand_more</span>
					</summary>
					<div class="p-6 pt-0 text-on-surface-variant">
						Evet, temel CV analizi tamamen ücretsizdir. Daha derinlemesine analiz ve mülakat koçluğu gibi özellikler için Premium paketimiz mevcuttur.
					</div>
				</details>
				<details class="group bg-surface border border-outline-variant rounded-xl overflow-hidden">
					<summary class="flex justify-between items-center p-6 cursor-pointer hover:bg-surface-container transition-colors">
						<span class="font-headline-md text-lg text-on-surface font-semibold">Hangi dosya formatlarını destekliyorsunuz?</span>
						<span class="material-symbols-outlined text-on-surface group-open:rotate-180 transition-transform">expand_more</span>
					</summary>
					<div class="p-6 pt-0 text-on-surface-variant">
						PDF (.pdf), Microsoft Word (.doc, .docx) ve düz metin (.txt) dosyalarını destekliyoruz. En iyi sonuç için PDF kullanmanızı öneririz.
					</div>
				</details>
				<details class="group bg-surface border border-outline-variant rounded-xl overflow-hidden">
					<summary class="flex justify-between items-center p-6 cursor-pointer hover:bg-surface-container transition-colors">
						<span class="font-headline-md text-lg text-on-surface font-semibold">Verilerim güvende mi?</span>
						<span class="material-symbols-outlined text-on-surface group-open:rotate-180 transition-transform">expand_more</span>
					</summary>
					<div class="p-6 pt-0 text-on-surface-variant">
						Kesinlikle. Verileriniz endüstri standardı şifreleme yöntemleriyle korunur ve asla üçüncü şahıslarla paylaşılmaz.
					</div>
				</details>
			</div>
		</section>

		<!-- Final CTA -->
		<section class="py-32 bg-gradient-to-t from-[#7c5cfc]/10 to-transparent">
			<div class="max-w-container-max mx-auto px-margin-mobile text-center">
				<h2 class="font-headline-lg-mobile md:font-headline-lg mb-6 text-on-surface font-bold">CV'nin potansiyelini keşfetmeye hazır mısın?</h2>
				<p class="text-body-lg text-on-surface-variant mb-10">Ücretsiz hesap oluştur, CV'ni analiz et ve hayalindeki işe bir adım daha yaklaş.</p>
				<a class="inline-flex items-center gap-3 bg-[#7c5cfc] text-white px-10 py-5 rounded-2xl font-bold text-xl hover:scale-105 transition-transform active:scale-95 shadow-lg shadow-[#7c5cfc]/20" href="/login">
					Hemen Başla
					<span class="material-symbols-outlined">rocket_launch</span>
				</a>
			</div>
		</section>
	</main>

	<!-- Footer -->
	<footer class="border-t border-outline-variant py-24 bg-background">
		<div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
			<div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-20">
				<!-- Brand Column -->
				<div class="space-y-6">
					<div class="font-headline-md text-headline-md font-bold text-on-surface flex items-center gap-2">
						<img src="/mixboard.png" alt="Beacon Logo" class="h-8 w-auto object-contain" />
						Beacon <span class="text-[#7c5cfc]">•</span>
					</div>
					<p class="text-on-surface-variant text-sm leading-relaxed max-w-xs">
						CV'lerin gerçek potansiyelini yapay zeka ile ortaya çıkarıyoruz. Kariyer yolculuğunuzda size rehberlik eden modern asistanınız.
					</p>
				</div>
				<!-- Product Column -->
				<div class="space-y-6">
					<h4 class="sc-header text-primary font-bold text-sm">Ürün</h4>
					<ul class="space-y-4 text-on-surface-variant text-sm font-label-md">
						<li><a class="hover:text-primary transition-colors" href="#">Özellikler</a></li>
						<li><a class="hover:text-primary transition-colors" href="#">Nasıl Çalışır</a></li>
						<li><a class="hover:text-primary transition-colors" href="#">Fiyatlandırma</a></li>
						<li><a class="hover:text-primary transition-colors" href="#">Geliştirici API</a></li>
					</ul>
				</div>
				<!-- Resources Column -->
				<div class="space-y-6">
					<h4 class="sc-header text-primary font-bold text-sm">Kaynaklar</h4>
					<ul class="space-y-4 text-on-surface-variant text-sm font-label-md">
						<li><a class="hover:text-primary transition-colors" href="#">Blog</a></li>
						<li><a class="hover:text-primary transition-colors" href="#">SSS</a></li>
						<li><a class="hover:text-primary transition-colors" href="#">Kariyer Rehberi</a></li>
						<li><a class="hover:text-primary transition-colors" href="#">Topluluk</a></li>
					</ul>
				</div>
				<!-- Legal Column -->
				<div class="space-y-6">
					<h4 class="sc-header text-primary font-bold text-sm">Yasal</h4>
					<ul class="space-y-4 text-on-surface-variant text-sm font-label-md">
						<li><a class="hover:text-primary transition-colors" href="#">Gizlilik Politikası</a></li>
						<li><a class="hover:text-primary transition-colors" href="#">Kullanım Koşulları</a></li>
						<li><a class="hover:text-primary transition-colors" href="#">Çerez Tercihleri</a></li>
					</ul>
				</div>
			</div>
			<!-- Bottom Bar -->
			<div class="pt-12 border-t border-outline-variant flex flex-col md:flex-row justify-between items-center gap-6">
				<div class="text-on-surface-variant font-label-sm">
					&copy; 2026 Beacon. Tüm hakları saklıdır.
				</div>
				<div class="flex items-center gap-6">
					<a class="text-on-surface-variant hover:text-primary transition-all hover:scale-110" href="#">
						<svg class="w-5 h-5 fill-current" viewbox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
					</a>
					<a class="text-on-surface-variant hover:text-primary transition-all hover:scale-110" href="#">
						<svg class="w-5 h-5 fill-current" viewbox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"></path></svg>
					</a>

                    </div>
</details>
</div>
</div>
</section>
<!-- 9. FINAL CTA -->
<section class="bg-primary-container py-24 px-margin-mobile md:px-margin-desktop text-center">
<div class="max-w-4xl mx-auto">
<h2 class="font-display text-headline-lg md:text-display text-white mb-8">CV'nin potansiyelini keşfetmeye hazır mısın?</h2>
<a href="/register" class="bg-white text-primary-container px-8 py-4 rounded-lg font-display text-body-md font-semibold hover:bg-surface transition-colors shadow-lg h-[52px] inline-flex items-center justify-center">Hemen Başla</a>
</div>
</section>

---
import '../styles/global.css';

interface Props {
  title?: string;
  bodyClass?: string;
}

const { title = "Beacon - Precision in Recruitment", bodyClass = "" } = Astro.props;
---

<!doctype html>
<html lang="tr" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<!-- Google Fonts & Icons -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700;800;900&family=Geist:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
		
		<!-- Material Icons & Symbols -->
		<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
		
		<!-- Lucide Icons -->
		<script is:inline src="https://unpkg.com/lucide@latest"></script>
	</head>
	<body class={`min-h-screen text-on-surface antialiased overflow-x-hidden selection:bg-primary-container selection:text-on-primary-container ${bodyClass}`}>
		<slot />
		
		<script is:inline>
			// Initialize Lucide icons if loaded
			if (window.lucide) {
				window.lucide.createIcons();
			}
		</script>
	</body>
</html>
